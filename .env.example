# BazaarPK — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# ─── Database ─────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=vibe_user
DB_PASSWORD=vibe_pass
DB_NAME=vibe_code_development

# ─── Redis / Sidekiq ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Rails ────────────────────────────────────────────────────────
RAILS_ENV=development
RAILS_MASTER_KEY=your_master_key_here
# Generate with: rails credentials:edit

# ─── Stripe (Subscriptions) ───────────────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe Price IDs for each plan
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...

# ─── JazzCash (Local Pakistani Payment) ──────────────────────────
JAZZCASH_MERCHANT_ID=
JAZZCASH_PASSWORD=
JAZZCASH_INTEGRITY_SALT=

# ─── EasyPaisa ────────────────────────────────────────────────────
EASYPAISA_STORE_ID=
EASYPAISA_HASH_KEY=

# ─── Active Storage / File Uploads ────────────────────────────────
# In development: files stored locally (no config needed)
# In production: use S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_BUCKET=bazaarpk-uploads

# ─── Email ────────────────────────────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=your_sendgrid_api_key
DEFAULT_FROM_EMAIL=noreply@bazaarpk.com

# ─── App ──────────────────────────────────────────────────────────
APP_HOST=localhost:3000
APP_NAME=BazaarPK
