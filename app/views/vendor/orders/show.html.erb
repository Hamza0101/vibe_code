<% content_for :page_title, "Order #{@order.order_number}" %>

<div class="max-w-2xl">

  <!-- Header -->
  <div class="flex items-center gap-3 mb-6">
    <%= link_to vendor_orders_path, class: "flex items-center gap-1.5 text-sm text-slate-500 hover:text-slate-700 font-medium transition" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/></svg>
      Orders
    <% end %>
    <span class="text-slate-300">/</span>
    <span class="text-sm font-bold text-slate-900"><%= @order.order_number %></span>

    <div class="ml-auto flex items-center gap-2">
      <% if @order.pos? %>
        <span class="inline-flex items-center gap-1 text-xs bg-violet-100 text-violet-700 px-2.5 py-1 rounded-full font-bold">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          POS Sale
        </span>
      <% else %>
        <span class="inline-flex items-center gap-1 text-xs bg-blue-100 text-blue-700 px-2.5 py-1 rounded-full font-bold">Online</span>
      <% end %>
      <span class="px-3 py-1 rounded-full text-xs font-bold
        <%= @order.pending? ? 'bg-amber-100 text-amber-700' :
            @order.delivered? ? 'bg-green-100 text-green-700' :
            @order.cancelled? ? 'bg-red-100 text-red-700' :
            @order.confirmed? ? 'bg-blue-100 text-blue-700' : 'bg-slate-100 text-slate-600' %>">
        <%= @order.status.humanize %>
      </span>
    </div>
  </div>

  <!-- Customer + Order Info -->
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 mb-4">
    <h2 class="font-bold text-slate-900 text-sm mb-4">Order Information</h2>
    <div class="grid grid-cols-2 gap-4 text-sm">
      <div>
        <p class="text-xs text-slate-400 font-semibold uppercase tracking-wide mb-1">Customer</p>
        <% if @order.pos? %>
          <p class="font-semibold text-slate-800"><%= @order.pos_customer_name.presence || "Walk-in Customer" %></p>
          <% if @order.pos_customer_phone.present? %>
            <p class="text-slate-500 text-xs mt-0.5"><%= @order.pos_customer_phone %></p>
          <% end %>
        <% else %>
          <p class="font-semibold text-slate-800"><%= @order.user&.name || @order.user&.email&.split("@")&.first || "—" %></p>
          <p class="text-slate-500 text-xs mt-0.5"><%= @order.user&.phone || "—" %></p>
        <% end %>
      </div>
      <div>
        <p class="text-xs text-slate-400 font-semibold uppercase tracking-wide mb-1">Payment</p>
        <p class="font-semibold text-slate-800"><%= @order.payment_method.humanize %></p>
      </div>
      <div>
        <p class="text-xs text-slate-400 font-semibold uppercase tracking-wide mb-1">Delivery Address</p>
        <p class="font-semibold text-slate-800"><%= @order.address&.full_address || (@order.pos? ? "In-store" : "Not specified") %></p>
      </div>
      <div>
        <p class="text-xs text-slate-400 font-semibold uppercase tracking-wide mb-1">Placed</p>
        <p class="font-semibold text-slate-800"><%= @order.created_at.strftime("%b %d, %Y · %I:%M %p") %></p>
      </div>
      <% if @order.notes.present? %>
        <div class="col-span-2">
          <p class="text-xs text-slate-400 font-semibold uppercase tracking-wide mb-1">Notes</p>
          <p class="text-slate-700 text-sm"><%= @order.notes %></p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Order Items -->
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 mb-4">
    <h2 class="font-bold text-slate-900 text-sm mb-4">Items (<%= @order_items.size %>)</h2>
    <div class="space-y-3 mb-5">
      <% @order_items.each do |item| %>
        <div class="flex items-center gap-3 py-2 border-b border-slate-100 last:border-0">
          <div class="w-10 h-10 bg-slate-100 rounded-xl flex-shrink-0 overflow-hidden">
            <% if item.product.images.attached? %>
              <%= image_tag item.product.primary_image, class: "w-full h-full object-cover" %>
            <% else %>
              <div class="w-full h-full flex items-center justify-center text-base">📦</div>
            <% end %>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-semibold text-slate-800 truncate"><%= item.product.name %></p>
            <% if item.variant_display.present? %>
              <p class="text-xs text-slate-400"><%= item.variant_display %></p>
            <% end %>
          </div>
          <div class="text-right flex-shrink-0">
            <p class="text-sm font-bold text-slate-900">Rs. <%= number_with_delimiter(item.line_total) %></p>
            <p class="text-xs text-slate-400">× <%= item.quantity %> @ Rs. <%= number_with_delimiter(item.unit_price) %></p>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Totals -->
    <div class="border-t border-slate-100 pt-4 space-y-2 text-sm">
      <div class="flex justify-between text-slate-500">
        <span>Subtotal</span>
        <span class="font-medium text-slate-700">Rs. <%= number_with_delimiter(@order.subtotal) %></span>
      </div>
      <div class="flex justify-between text-slate-500">
        <span>Delivery</span>
        <span class="font-medium text-slate-700"><%= @order.delivery_fee.to_i.zero? ? "Free" : "Rs. #{number_with_delimiter(@order.delivery_fee)}" %></span>
      </div>
      <div class="flex justify-between font-bold text-base pt-2 border-t border-slate-100">
        <span class="text-slate-900">Total</span>
        <span class="text-green-700">Rs. <%= number_with_delimiter(@order.total) %></span>
      </div>
    </div>
  </div>

  <!-- Update Status -->
  <% unless @order.cancelled? || @order.delivered? %>
    <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
      <h3 class="font-bold text-slate-900 text-sm mb-4">Update Status</h3>
      <%= form_with url: vendor_order_path(@order), method: :patch, class: "flex items-center gap-3" do |f| %>
        <%= f.select :status,
              Order.statuses.keys.map { |s| [s.humanize, s] },
              { selected: @order.status },
              class: "flex-1 bg-slate-50 border border-slate-200 rounded-xl px-4 py-2.5 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-green-500" %>
        <%= f.submit "Update Status",
              class: "bg-green-600 hover:bg-green-700 text-white font-semibold px-5 py-2.5 rounded-xl text-sm cursor-pointer transition shadow-sm" %>
      <% end %>
    </div>
  <% end %>
</div>
