<% content_for :page_title, "Store Settings" %>

<div class="max-w-3xl">
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
    <h2 class="font-bold text-slate-900 mb-6">Store Profile</h2>

    <%= form_with model: [:vendor, @store], class: "space-y-6" do |f| %>
      <% if @store.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-xl p-4 text-sm text-red-700">
          <% @store.errors.full_messages.each do |m| %><p>• <%= m %></p><% end %>
        </div>
      <% end %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div>
          <%= f.label :name, "Store Name", class: "block text-xs font-bold text-slate-500 uppercase tracking-wide mb-1.5" %>
          <%= f.text_field :name, placeholder: "Your store name",
                class: "w-full border border-slate-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" %>
        </div>
        <div>
          <%= f.label :category, "Store Type", class: "block text-xs font-bold text-slate-500 uppercase tracking-wide mb-1.5" %>
          <%= f.select :category, Store.categories.keys.map { |c| [c.humanize, c] },
                { include_blank: "Select type..." },
                class: "w-full border border-slate-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" %>
        </div>
        <div>
          <%= f.label :city, "City", class: "block text-xs font-bold text-slate-500 uppercase tracking-wide mb-1.5" %>
          <%= f.text_field :city, placeholder: "e.g. Karachi",
                class: "w-full border border-slate-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" %>
        </div>
        <div>
          <%= f.label :phone, "Phone Number", class: "block text-xs font-bold text-slate-500 uppercase tracking-wide mb-1.5" %>
          <%= f.text_field :phone, placeholder: "03001234567",
                class: "w-full border border-slate-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" %>
        </div>
      </div>

      <div>
        <%= f.label :address, "Store Address", class: "block text-xs font-bold text-slate-500 uppercase tracking-wide mb-1.5" %>
        <%= f.text_field :address, placeholder: "Full store address",
              class: "w-full border border-slate-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" %>
      </div>

      <div>
        <%= f.label :description, "About Your Store", class: "block text-xs font-bold text-slate-500 uppercase tracking-wide mb-1.5" %>
        <%= f.text_area :description, rows: 3,
              placeholder: "Tell customers what makes your store special...",
              class: "w-full border border-slate-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 resize-none" %>
      </div>

      <!-- Images -->
      <div>
        <p class="text-xs font-bold text-slate-500 uppercase tracking-wide mb-3">Store Images</p>
        <div class="grid grid-cols-2 gap-4">
          <div class="border-2 border-dashed border-slate-200 rounded-xl p-5 text-center hover:border-green-400 transition">
            <div class="w-10 h-10 bg-slate-100 rounded-xl flex items-center justify-center mx-auto mb-2">
              <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <%= f.label :logo, "Store Logo", class: "block text-xs font-semibold text-slate-600 mb-1 cursor-pointer" %>
            <p class="text-xs text-slate-400 mb-2">Square image recommended</p>
            <%= f.file_field :logo, accept: "image/*",
                  class: "text-xs text-slate-500 file:mr-2 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-slate-100 file:text-slate-600 hover:file:bg-slate-200" %>
            <% if @store.logo.attached? %>
              <p class="text-xs text-green-600 font-medium mt-1">✓ Logo uploaded</p>
            <% end %>
          </div>
          <div class="border-2 border-dashed border-slate-200 rounded-xl p-5 text-center hover:border-green-400 transition">
            <div class="w-10 h-10 bg-slate-100 rounded-xl flex items-center justify-center mx-auto mb-2">
              <svg class="w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <%= f.label :banner, "Banner Image", class: "block text-xs font-semibold text-slate-600 mb-1 cursor-pointer" %>
            <p class="text-xs text-slate-400 mb-2">Wide landscape image</p>
            <%= f.file_field :banner, accept: "image/*",
                  class: "text-xs text-slate-500 file:mr-2 file:py-1 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-slate-100 file:text-slate-600 hover:file:bg-slate-200" %>
            <% if @store.banner.attached? %>
              <p class="text-xs text-green-600 font-medium mt-1">✓ Banner uploaded</p>
            <% end %>
          </div>
        </div>
      </div>

      <div class="flex items-center gap-3 pt-2">
        <%= f.submit @store.new_record? ? "Create Store" : "Save Changes",
              class: "bg-green-600 hover:bg-green-700 text-white font-bold px-8 py-3 rounded-xl cursor-pointer transition shadow-sm" %>
        <%= link_to "Cancel", vendor_store_path, class: "text-slate-500 hover:text-slate-700 font-medium text-sm px-4 py-3" %>
      </div>
    <% end %>
  </div>
</div>
