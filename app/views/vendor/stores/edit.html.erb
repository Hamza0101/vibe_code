<% content_for :page_title, "My Store Settings" %>

<div class="max-w-2xl">
  <div class="bg-white rounded-xl shadow p-6">
    <%= form_with model: [:vendor, @store], class: "space-y-4" do |f| %>
      <% if @store.errors.any? %>
        <div class="bg-red-50 border border-red-300 rounded p-3 text-sm text-red-700">
          <% @store.errors.full_messages.each { |m| %><p>• <%= m %></p><% } %>
        </div>
      <% end %>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :name, class: "w-full border rounded px-3 py-2 text-sm" %>
        </div>
        <div>
          <%= f.label :category, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.select :category, Store.categories.keys.map { |c| [c.humanize, c] },
                { include_blank: "Select type..." }, class: "w-full border rounded px-3 py-2 text-sm" %>
        </div>
        <div>
          <%= f.label :city, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :city, class: "w-full border rounded px-3 py-2 text-sm" %>
        </div>
        <div>
          <%= f.label :phone, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :phone, placeholder: "03001234567", class: "w-full border rounded px-3 py-2 text-sm" %>
        </div>
      </div>

      <div>
        <%= f.label :address, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :address, class: "w-full border rounded px-3 py-2 text-sm" %>
      </div>

      <div>
        <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :description, rows: 3, class: "w-full border rounded px-3 py-2 text-sm" %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :logo, "Store Logo", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.file_field :logo, accept: "image/*", class: "text-sm" %>
        </div>
        <div>
          <%= f.label :banner, "Banner Image", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.file_field :banner, accept: "image/*", class: "text-sm" %>
        </div>
      </div>

      <%= f.submit @store.new_record? ? "Create Store" : "Save Changes",
            class: "bg-green-600 hover:bg-green-700 text-white px-6 py-2 rounded font-medium cursor-pointer" %>
    <% end %>
  </div>
</div>
