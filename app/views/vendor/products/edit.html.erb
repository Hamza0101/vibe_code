<% content_for :page_title, "Edit Product" %>

<div class="max-w-3xl space-y-5">
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
    <%= render "form", product: @product %>
  </div>

  <!-- Variants -->
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
    <h3 class="font-bold text-slate-900 mb-5">Product Variants
      <span class="text-xs text-slate-400 font-normal ml-2">size, color, weight, etc.</span>
    </h3>

    <% if @product.product_variants.any? %>
      <div class="border border-slate-200 rounded-xl overflow-hidden mb-5">
        <table class="w-full text-sm">
          <thead class="bg-slate-50 border-b border-slate-200">
            <tr>
              <th class="px-4 py-2.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Type</th>
              <th class="px-4 py-2.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Value</th>
              <th class="px-4 py-2.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Price +Rs.</th>
              <th class="px-4 py-2.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Stock</th>
              <th class="px-4 py-2.5"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @product.product_variants.each do |variant| %>
              <tr class="hover:bg-slate-50/50">
                <td class="px-4 py-3 text-slate-700"><%= variant.name %></td>
                <td class="px-4 py-3 font-semibold text-slate-900"><%= variant.value %></td>
                <td class="px-4 py-3 text-slate-700">+Rs. <%= number_with_delimiter(variant.price_modifier) %></td>
                <td class="px-4 py-3 text-slate-700"><%= variant.stock || "∞" %></td>
                <td class="px-4 py-3 text-right">
                  <%= button_to vendor_variant_path(variant), method: :delete,
                        class: "text-xs text-red-500 hover:text-red-700 font-medium" do %>
                    Remove
                  <% end %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>

    <div class="bg-slate-50 rounded-xl p-4">
      <p class="text-xs font-bold text-slate-500 uppercase tracking-wide mb-3">Add Variant</p>
      <%= form_with url: vendor_product_variants_path(@product), method: :post, class: "flex gap-3 flex-wrap items-end" do |f| %>
        <div>
          <label class="block text-xs text-slate-500 font-medium mb-1.5">Type</label>
          <%= text_field_tag "product_variant[name]", "", placeholder: "e.g. Size",
                class: "border border-slate-200 rounded-xl px-3 py-2 text-sm w-28 focus:outline-none focus:ring-2 focus:ring-green-500" %>
        </div>
        <div>
          <label class="block text-xs text-slate-500 font-medium mb-1.5">Value</label>
          <%= text_field_tag "product_variant[value]", "", placeholder: "e.g. XL",
                class: "border border-slate-200 rounded-xl px-3 py-2 text-sm w-24 focus:outline-none focus:ring-2 focus:ring-green-500" %>
        </div>
        <div>
          <label class="block text-xs text-slate-500 font-medium mb-1.5">Price +Rs.</label>
          <%= number_field_tag "product_variant[price_modifier]", 0, step: 1,
                class: "border border-slate-200 rounded-xl px-3 py-2 text-sm w-24 focus:outline-none focus:ring-2 focus:ring-green-500" %>
        </div>
        <div>
          <label class="block text-xs text-slate-500 font-medium mb-1.5">Stock</label>
          <%= number_field_tag "product_variant[stock]", nil, min: 0, placeholder: "∞",
                class: "border border-slate-200 rounded-xl px-3 py-2 text-sm w-20 focus:outline-none focus:ring-2 focus:ring-green-500" %>
        </div>
        <%= submit_tag "+ Add Variant",
              class: "bg-slate-800 hover:bg-slate-900 text-white px-4 py-2 rounded-xl text-sm cursor-pointer font-semibold transition" %>
      <% end %>
    </div>
  </div>
</div>
