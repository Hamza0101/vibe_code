<%= form_with model: [:vendor, product], class: "space-y-4" do |f| %>
  <% if product.errors.any? %>
    <div class="bg-red-50 border border-red-300 rounded p-3 text-sm text-red-700">
      <% product.errors.full_messages.each do |msg| %>
        <p>• <%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <%= f.label :name, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name, class: "w-full border rounded px-3 py-2 text-sm focus:ring-green-500 focus:border-green-500" %>
    </div>

    <div>
      <%= f.label :price, "Price (Rs.)", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :price, step: 0.01, min: 0, class: "w-full border rounded px-3 py-2 text-sm" %>
    </div>

    <div>
      <%= f.label :stock, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.number_field :stock, min: 0, placeholder: "Leave blank for unlimited",
            class: "w-full border rounded px-3 py-2 text-sm" %>
    </div>

    <div>
      <%= f.label :category_id, "Category", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.collection_select :category_id, Category.ordered, :id, :name,
            { include_blank: "— Select Category —" }, class: "w-full border rounded px-3 py-2 text-sm" %>
    </div>
  </div>

  <div>
    <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 4, class: "w-full border rounded px-3 py-2 text-sm" %>
  </div>

  <div>
    <%= f.label :images, "Product Images", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.file_field :images, multiple: true, accept: "image/*", class: "w-full text-sm" %>
  </div>

  <div class="flex items-center space-x-4">
    <label class="flex items-center space-x-2">
      <%= f.check_box :published %>
      <span class="text-sm">Published (visible to customers)</span>
    </label>
    <label class="flex items-center space-x-2">
      <%= f.check_box :featured %>
      <span class="text-sm">Featured</span>
    </label>
  </div>

  <%= f.submit product.new_record? ? "Create Product" : "Update Product",
        class: "bg-green-600 hover:bg-green-700 text-white px-6 py-2 rounded font-medium cursor-pointer" %>
<% end %>
