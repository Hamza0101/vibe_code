<% content_for :page_title, "Products" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <p class="text-sm text-slate-500">
      <span class="font-bold text-slate-900"><%= @pagy.count rescue current_store.products.count %></span> products
      <% if @product_limit %>
        <span class="text-slate-400">of <%= @product_limit %> allowed</span>
      <% end %>
    </p>
  </div>
  <%= link_to new_vendor_product_path, class: "flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white font-semibold px-4 py-2.5 rounded-xl transition shadow-sm text-sm" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    Add Product
  <% end %>
</div>

<div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
  <% if @products.any? %>
    <table class="w-full text-sm">
      <thead class="border-b border-slate-100 bg-slate-50">
        <tr>
          <th class="px-5 py-3.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Product</th>
          <th class="px-5 py-3.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Price</th>
          <th class="px-5 py-3.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Stock</th>
          <th class="px-5 py-3.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Status</th>
          <th class="px-5 py-3.5"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @products.each do |product| %>
          <tr class="hover:bg-slate-50/50 transition">
            <td class="px-5 py-4">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-slate-100 flex-shrink-0 overflow-hidden">
                  <% if product.images.attached? %>
                    <%= image_tag product.primary_image, class: "w-full h-full object-cover" %>
                  <% else %>
                    <div class="w-full h-full flex items-center justify-center text-lg">📦</div>
                  <% end %>
                </div>
                <div>
                  <p class="font-semibold text-slate-900 text-sm"><%= product.name %></p>
                  <p class="text-xs text-slate-400 mt-0.5"><%= product.category&.name || "Uncategorized" %></p>
                </div>
              </div>
            </td>
            <td class="px-5 py-4 font-semibold text-slate-800">Rs. <%= number_with_delimiter(product.price) %></td>
            <td class="px-5 py-4">
              <% if product.stock.nil? %>
                <span class="text-slate-400 text-xs">Unlimited</span>
              <% elsif product.stock == 0 %>
                <span class="text-xs font-bold text-red-600 bg-red-50 px-2 py-0.5 rounded-full">Out of stock</span>
              <% elsif product.stock <= 5 %>
                <span class="text-xs font-bold text-amber-600 bg-amber-50 px-2 py-0.5 rounded-full"><%= product.stock %> left</span>
              <% else %>
                <span class="text-slate-700 font-medium"><%= product.stock %></span>
              <% end %>
            </td>
            <td class="px-5 py-4">
              <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold
                <%= product.published? ? 'bg-green-100 text-green-700' : 'bg-slate-100 text-slate-500' %>">
                <span class="w-1.5 h-1.5 rounded-full <%= product.published? ? 'bg-green-500' : 'bg-slate-400' %>"></span>
                <%= product.published? ? "Published" : "Draft" %>
              </span>
            </td>
            <td class="px-5 py-4 text-right">
              <div class="flex items-center justify-end gap-2">
                <%= link_to edit_vendor_product_path(product),
                      class: "p-2 text-slate-400 hover:text-slate-700 hover:bg-slate-100 rounded-xl transition" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                <% end %>
                <%= button_to vendor_product_path(product), method: :delete,
                      class: "p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-xl transition",
                      data: { confirm: "Delete #{product.name}? This cannot be undone." } do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <div class="p-4 border-t border-slate-100"><%== pagy_nav(@pagy) %></div>
  <% else %>
    <div class="text-center py-20">
      <div class="w-16 h-16 bg-slate-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
      </div>
      <h3 class="text-lg font-semibold text-slate-700 mb-2">No products yet</h3>
      <p class="text-slate-400 text-sm mb-5">Start listing your products to accept orders</p>
      <%= link_to "Add Your First Product", new_vendor_product_path,
            class: "bg-green-600 hover:bg-green-700 text-white font-semibold px-6 py-3 rounded-xl transition shadow-sm text-sm" %>
    </div>
  <% end %>
</div>
