<% content_for :page_title, "Products" %>

<div class="flex items-center justify-between mb-6">
  <h2 class="text-lg font-semibold text-gray-700"><%= current_store.products.count %> Products</h2>
  <%= link_to "+ Add Product", new_vendor_product_path, class: "bg-green-600 hover:bg-green-700 text-white px-4 py-2 rounded font-medium" %>
</div>

<div class="bg-white rounded-xl shadow overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-gray-50 border-b">
      <tr>
        <th class="px-4 py-3 text-left">Product</th>
        <th class="px-4 py-3 text-left">Price</th>
        <th class="px-4 py-3 text-left">Stock</th>
        <th class="px-4 py-3 text-left">Status</th>
        <th class="px-4 py-3"></th>
      </tr>
    </thead>
    <tbody>
      <% @products.each do |product| %>
        <tr class="border-b hover:bg-gray-50">
          <td class="px-4 py-3">
            <p class="font-medium"><%= product.name %></p>
            <p class="text-xs text-gray-400"><%= product.category&.name %></p>
          </td>
          <td class="px-4 py-3">Rs. <%= number_with_delimiter(product.price) %></td>
          <td class="px-4 py-3">
            <% if product.stock.nil? %>
              <span class="text-gray-400">Unlimited</span>
            <% elsif product.stock <= 5 %>
              <span class="text-red-600 font-semibold"><%= product.stock %></span>
            <% else %>
              <%= product.stock %>
            <% end %>
          </td>
          <td class="px-4 py-3">
            <span class="px-2 py-0.5 rounded-full text-xs <%= product.published? ? 'bg-green-100 text-green-700' : 'bg-gray-100 text-gray-500' %>">
              <%= product.published? ? "Published" : "Draft" %>
            </span>
          </td>
          <td class="px-4 py-3 text-right space-x-2">
            <%= link_to "Edit", edit_vendor_product_path(product), class: "text-blue-600 hover:underline" %>
            <%= button_to "Delete", vendor_product_path(product), method: :delete,
                  class: "text-red-600 hover:underline",
                  data: { confirm: "Delete #{product.name}?" } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <% if @products.empty? %>
    <div class="text-center py-12 text-gray-500">
      <p>No products yet. <%= link_to "Add your first product", new_vendor_product_path, class: "text-green-600 underline" %></p>
    </div>
  <% end %>
</div>

<div class="mt-4"><%== pagy_nav(@pagy) %></div>
