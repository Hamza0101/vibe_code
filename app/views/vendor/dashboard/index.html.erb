<% content_for :page_title, "Dashboard" %>

<!-- Stats -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5">
    <div class="flex items-center justify-between mb-3">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Products</p>
      <div class="w-8 h-8 bg-blue-50 rounded-xl flex items-center justify-center">
        <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
      </div>
    </div>
    <p class="text-3xl font-black text-slate-900"><%= @total_products %></p>
    <% if @product_limit %>
      <div class="mt-2">
        <div class="flex justify-between text-xs text-slate-400 mb-1">
          <span><%= @total_products %> / <%= @product_limit %></span>
          <span><%= [(@total_products.to_f / @product_limit * 100).round, 100].min %>%</span>
        </div>
        <div class="w-full bg-slate-100 rounded-full h-1.5">
          <div class="bg-blue-500 h-1.5 rounded-full transition-all" style="width: <%= [(@total_products.to_f / @product_limit * 100), 100].min %>%"></div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5">
    <div class="flex items-center justify-between mb-3">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Pending</p>
      <div class="w-8 h-8 bg-amber-50 rounded-xl flex items-center justify-center">
        <svg class="w-4 h-4 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
    </div>
    <p class="text-3xl font-black text-amber-600"><%= @pending_orders %></p>
    <p class="text-xs text-slate-400 mt-1">Orders awaiting action</p>
  </div>

  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5">
    <div class="flex items-center justify-between mb-3">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide">This Month</p>
      <div class="w-8 h-8 bg-green-50 rounded-xl flex items-center justify-center">
        <svg class="w-4 h-4 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
      </div>
    </div>
    <p class="text-2xl font-black text-green-700">Rs. <%= number_with_delimiter(@revenue_this_month) %></p>
    <p class="text-xs text-slate-400 mt-1">Revenue this month</p>
  </div>

  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5">
    <div class="flex items-center justify-between mb-3">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Total Revenue</p>
      <div class="w-8 h-8 bg-slate-100 rounded-xl flex items-center justify-center">
        <svg class="w-4 h-4 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
    </div>
    <p class="text-2xl font-black text-slate-900">Rs. <%= number_with_delimiter(@total_revenue) %></p>
    <p class="text-xs text-slate-400 mt-1">All time</p>
  </div>
</div>

<!-- Plan Banner -->
<% if @plan %>
  <div class="bg-white rounded-2xl border-2 <%= @plan.free? ? 'border-amber-200 bg-amber-50' : 'border-green-200 bg-green-50' %> p-5 mb-6 flex items-center justify-between gap-4">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-xl <%= @plan.free? ? 'bg-amber-100' : 'bg-green-100' %> flex items-center justify-center">
        <svg class="w-5 h-5 <%= @plan.free? ? 'text-amber-600' : 'text-green-600' %>" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
      </div>
      <div>
        <p class="font-bold text-slate-900 text-sm"><%= @plan.name %> Plan</p>
        <p class="text-xs text-slate-500 mt-0.5">
          <%= @plan.free? ? "Upgrade to unlock analytics, featured listing & more." : "You're on a paid plan. Enjoy all premium features." %>
        </p>
      </div>
    </div>
    <%= link_to subscriptions_path, class: "flex-shrink-0 bg-green-600 hover:bg-green-700 text-white text-xs font-bold px-4 py-2.5 rounded-xl transition shadow-sm" do %>
      <%= @plan.free? ? "Upgrade Plan" : "Manage Plan" %>
    <% end %>
  </div>
<% end %>

<!-- Recent Orders + Low Stock -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-5">
  <!-- Recent Orders -->
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5">
    <div class="flex items-center justify-between mb-4">
      <h2 class="font-bold text-slate-900 text-sm">Recent Orders</h2>
      <%= link_to "View all", vendor_orders_path, class: "text-xs text-green-700 hover:text-green-800 font-semibold" %>
    </div>
    <% if @recent_orders.any? %>
      <div class="space-y-3">
        <% @recent_orders.each do |order| %>
          <div class="flex items-center justify-between py-2 border-b border-slate-100 last:border-0">
            <div>
              <p class="text-sm font-semibold text-slate-800">#<%= order.order_number %></p>
              <p class="text-xs text-slate-400 mt-0.5">
                <%= order.pos? ? (order.pos_customer_name.presence || "Walk-in") : (order.user&.name || order.user&.email&.split("@")&.first || "—") %>
              </p>
            </div>
            <div class="text-right">
              <span class="inline-block text-xs px-2.5 py-0.5 rounded-full font-semibold
                <%= order.pending? ? 'bg-amber-100 text-amber-700' :
                    order.delivered? ? 'bg-green-100 text-green-700' :
                    order.cancelled? ? 'bg-red-100 text-red-700' : 'bg-blue-100 text-blue-700' %>">
                <%= order.status.humanize %>
              </span>
              <p class="text-sm font-bold text-slate-900 mt-1">Rs. <%= number_with_delimiter(order.total) %></p>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-8">
        <p class="text-4xl mb-2">📭</p>
        <p class="text-slate-400 text-sm">No orders yet</p>
      </div>
    <% end %>
  </div>

  <!-- Low Stock -->
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5">
    <div class="flex items-center justify-between mb-4">
      <h2 class="font-bold text-slate-900 text-sm flex items-center gap-2">
        <span class="w-5 h-5 bg-red-100 text-red-600 rounded flex items-center justify-center text-xs">!</span>
        Low Stock
      </h2>
      <%= link_to "Manage", vendor_products_path, class: "text-xs text-green-700 hover:text-green-800 font-semibold" %>
    </div>
    <% if @low_stock_products.any? %>
      <div class="space-y-3">
        <% @low_stock_products.each do |product| %>
          <div class="flex items-center justify-between py-2 border-b border-slate-100 last:border-0">
            <p class="text-sm text-slate-700 font-medium truncate pr-4"><%= product.name %></p>
            <span class="text-xs font-bold px-2.5 py-1 rounded-full flex-shrink-0
              <%= product.stock == 0 ? 'bg-red-100 text-red-700' : 'bg-amber-100 text-amber-700' %>">
              <%= product.stock == 0 ? "Out of stock" : "#{product.stock} left" %>
            </span>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-8">
        <p class="text-4xl mb-2">✅</p>
        <p class="text-slate-400 text-sm">All products well stocked</p>
      </div>
    <% end %>
  </div>
</div>
