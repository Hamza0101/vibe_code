<% content_for :page_title, "Dashboard" %>

<!-- Stats -->
<div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">

  <!-- Products -->
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5">
    <div class="flex items-start justify-between mb-3">
      <div>
        <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Products</p>
        <p class="text-3xl font-black text-slate-900 mt-1.5"><%= @total_products %></p>
      </div>
      <div class="w-10 h-10 bg-blue-50 rounded-xl flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
      </div>
    </div>
    <% if @product_limit %>
      <div class="mt-3">
        <div class="flex justify-between text-xs text-slate-400 mb-1.5">
          <span class="font-medium"><%= @total_products %> of <%= @product_limit %> used</span>
          <span><%= [(@total_products.to_f / @product_limit * 100).round, 100].min %>%</span>
        </div>
        <div class="w-full bg-slate-100 rounded-full h-1.5 overflow-hidden">
          <div class="bg-blue-500 h-1.5 rounded-full transition-all duration-500" style="width: <%= [(@total_products.to_f / @product_limit * 100), 100].min %>%"></div>
        </div>
      </div>
    <% else %>
      <p class="text-xs text-slate-400 mt-1">Total listed products</p>
    <% end %>
  </div>

  <!-- Pending Orders -->
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5">
    <div class="flex items-start justify-between mb-3">
      <div>
        <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Pending Orders</p>
        <p class="text-3xl font-black text-amber-600 mt-1.5"><%= @pending_orders %></p>
      </div>
      <div class="w-10 h-10 bg-amber-50 rounded-xl flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
    </div>
    <div class="flex items-center gap-1 mt-1">
      <svg class="w-3.5 h-3.5 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      <p class="text-xs text-slate-400">Awaiting action</p>
    </div>
  </div>

  <!-- Monthly Revenue -->
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5">
    <div class="flex items-start justify-between mb-3">
      <div>
        <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide">This Month</p>
        <p class="text-2xl font-black text-green-700 mt-1.5">Rs. <%= number_with_delimiter(@revenue_this_month) %></p>
      </div>
      <div class="w-10 h-10 bg-green-50 rounded-xl flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
      </div>
    </div>
    <div class="flex items-center gap-1 mt-1">
      <svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>
      <p class="text-xs text-slate-400">Revenue this month</p>
    </div>
  </div>

  <!-- Total Revenue -->
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5">
    <div class="flex items-start justify-between mb-3">
      <div>
        <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Total Revenue</p>
        <p class="text-2xl font-black text-slate-900 mt-1.5">Rs. <%= number_with_delimiter(@total_revenue) %></p>
      </div>
      <div class="w-10 h-10 bg-slate-100 rounded-xl flex items-center justify-center flex-shrink-0">
        <svg class="w-5 h-5 text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
      </div>
    </div>
    <div class="flex items-center gap-1 mt-1">
      <svg class="w-3.5 h-3.5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
      <p class="text-xs text-slate-400">All time</p>
    </div>
  </div>

</div>

<!-- Plan Banner -->
<% if @plan %>
  <div class="rounded-2xl border-2 p-5 mb-6 flex items-center justify-between gap-4
    <%= @plan.free? ? 'bg-amber-50 border-amber-200' : 'bg-green-50 border-green-200' %>">
    <div class="flex items-center gap-4">
      <div class="w-11 h-11 rounded-xl flex items-center justify-center flex-shrink-0
        <%= @plan.free? ? 'bg-amber-100' : 'bg-green-100' %>">
        <% if @plan.free? %>
          <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
        <% else %>
          <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        <% end %>
      </div>
      <div>
        <p class="font-bold text-slate-900 text-sm">
          <%= @plan.name %> Plan
          <% unless @plan.free? %>
            <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-700">Active</span>
          <% end %>
        </p>
        <p class="text-xs text-slate-500 mt-0.5">
          <%= @plan.free? ? "Upgrade to unlock analytics, featured listing & more." : "You're on a paid plan. Enjoy all premium features." %>
        </p>
      </div>
    </div>
    <%= link_to subscriptions_path,
          class: "flex-shrink-0 flex items-center gap-2 text-white text-xs font-bold px-4 py-2.5 rounded-xl transition shadow-sm
            #{@plan.free? ? 'bg-amber-500 hover:bg-amber-600' : 'bg-green-600 hover:bg-green-700'}" do %>
      <% if @plan.free? %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18"/></svg>
        Upgrade Plan
      <% else %>
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Manage Plan
      <% end %>
    <% end %>
  </div>
<% end %>

<!-- Recent Orders + Low Stock -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-5">

  <!-- Recent Orders -->
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
    <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100">
      <h2 class="font-bold text-slate-900 text-sm">Recent Orders</h2>
      <%= link_to vendor_orders_path, class: "text-xs text-green-700 hover:text-green-800 font-semibold flex items-center gap-1" do %>
        View all
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <% end %>
    </div>

    <% if @recent_orders.any? %>
      <table class="w-full text-sm">
        <thead class="bg-slate-50 border-b border-slate-100">
          <tr>
            <th class="px-5 py-2.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wide">Order</th>
            <th class="px-5 py-2.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wide">Customer</th>
            <th class="px-5 py-2.5 text-left text-xs font-semibold text-slate-400 uppercase tracking-wide">Status</th>
            <th class="px-5 py-2.5 text-right text-xs font-semibold text-slate-400 uppercase tracking-wide">Amount</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @recent_orders.each do |order| %>
            <tr class="hover:bg-slate-50 transition">
              <td class="px-5 py-3 font-semibold text-slate-900 text-xs">#<%= order.order_number %></td>
              <td class="px-5 py-3 text-slate-600 text-xs truncate max-w-[100px]">
                <%= order.pos? ? (order.pos_customer_name.presence || "Walk-in") : (order.user&.name || order.user&.email&.split("@")&.first || "—") %>
              </td>
              <td class="px-5 py-3">
                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold
                  <%= order.pending? ? 'bg-amber-100 text-amber-700' :
                      order.delivered? ? 'bg-green-100 text-green-700' :
                      order.cancelled? ? 'bg-red-100 text-red-700' : 'bg-blue-100 text-blue-700' %>">
                  <span class="w-1.5 h-1.5 rounded-full flex-shrink-0
                    <%= order.pending? ? 'bg-amber-500' :
                        order.delivered? ? 'bg-green-500' :
                        order.cancelled? ? 'bg-red-500' : 'bg-blue-500' %>"></span>
                  <%= order.status.humanize %>
                </span>
              </td>
              <td class="px-5 py-3 font-bold text-slate-900 text-xs text-right">Rs. <%= number_with_delimiter(order.total) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="flex flex-col items-center justify-center py-14 px-5">
        <div class="w-14 h-14 bg-slate-100 rounded-2xl flex items-center justify-center mb-4">
          <svg class="w-7 h-7 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
          </svg>
        </div>
        <p class="text-sm font-semibold text-slate-600 mb-1">No orders yet</p>
        <p class="text-xs text-slate-400 text-center">Orders will appear here once customers start buying.</p>
      </div>
    <% end %>
  </div>

  <!-- Low Stock -->
  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
    <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100">
      <h2 class="font-bold text-slate-900 text-sm flex items-center gap-2">
        <span class="w-5 h-5 bg-red-50 text-red-500 rounded-lg flex items-center justify-center">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01"/></svg>
        </span>
        Low Stock
      </h2>
      <%= link_to vendor_products_path, class: "text-xs text-green-700 hover:text-green-800 font-semibold flex items-center gap-1" do %>
        Manage
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <% end %>
    </div>

    <% if @low_stock_products.any? %>
      <div class="divide-y divide-slate-100">
        <% @low_stock_products.each do |product| %>
          <div class="flex items-center justify-between px-5 py-3.5 hover:bg-slate-50 transition">
            <div class="flex items-center gap-3 min-w-0">
              <div class="w-2 h-2 rounded-full flex-shrink-0 <%= product.stock == 0 ? 'bg-red-500' : 'bg-amber-500' %>"></div>
              <p class="text-sm text-slate-700 font-medium truncate"><%= product.name %></p>
            </div>
            <span class="text-xs font-bold px-2.5 py-1 rounded-full flex-shrink-0 ml-3
              <%= product.stock == 0 ? 'bg-red-100 text-red-700' : 'bg-amber-100 text-amber-700' %>">
              <%= product.stock == 0 ? "Out of stock" : "#{product.stock} left" %>
            </span>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="flex flex-col items-center justify-center py-14 px-5">
        <div class="w-14 h-14 bg-green-50 rounded-2xl flex items-center justify-center mb-4">
          <svg class="w-7 h-7 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <p class="text-sm font-semibold text-slate-600 mb-1">All products well stocked</p>
        <p class="text-xs text-slate-400 text-center">No inventory alerts at this time.</p>
      </div>
    <% end %>
  </div>

</div>
