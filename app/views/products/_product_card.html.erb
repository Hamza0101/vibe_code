<div class="group bg-white rounded-2xl border border-slate-200 overflow-hidden hover:border-green-300 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 flex flex-col">
  <%= link_to product_path(product), class: "flex-1 flex flex-col" do %>
    <!-- Image -->
    <div class="aspect-square overflow-hidden relative bg-slate-100">
      <% if product.images.attached? %>
        <%= image_tag product.primary_image, class: "w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" %>
      <% else %>
        <div class="w-full h-full flex items-center justify-center bg-slate-50">
          <svg class="w-10 h-10 text-slate-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.25" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
        </div>
      <% end %>
      <% unless product.in_stock? %>
        <div class="absolute inset-0 bg-black/50 flex items-center justify-center">
          <span class="bg-red-600 text-white text-xs font-bold px-3 py-1 rounded-full shadow">Out of Stock</span>
        </div>
      <% end %>
    </div>

    <!-- Info -->
    <div class="p-3.5 flex-1 flex flex-col">
      <p class="text-xs text-slate-400 font-medium mb-1 truncate"><%= product.store.name %></p>
      <h3 class="font-bold text-slate-900 text-sm line-clamp-2 leading-snug group-hover:text-green-700 transition flex-1"><%= product.name %></h3>
      <p class="font-black text-green-700 text-base mt-2">Rs. <%= number_with_delimiter(product.price) %></p>
    </div>
  <% end %>

  <!-- Add to cart -->
  <div class="px-3.5 pb-3.5">
    <%= button_to add_item_cart_path, method: :post, params: { product_id: product.id },
          class: "w-full py-2.5 rounded-xl text-xs font-bold transition duration-150 #{ product.in_stock? ? 'bg-green-600 hover:bg-green-700 active:bg-green-800 text-white shadow-sm cursor-pointer' : 'bg-slate-100 text-slate-400 cursor-not-allowed' }",
          disabled: !product.in_stock? do %>
      <% if product.in_stock? %>
        <span class="flex items-center justify-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
          Add to Cart
        </span>
      <% else %>
        Unavailable
      <% end %>
    <% end %>
  </div>
</div>
