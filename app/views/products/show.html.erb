<% content_for :title, @product.name %>

<div class="max-w-5xl mx-auto px-4 py-8">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8 bg-white rounded-xl shadow p-6">
    <!-- Images -->
    <div>
      <% if @product.images.attached? %>
        <%= image_tag @product.primary_image, class: "w-full rounded-lg object-cover max-h-80" %>
        <% if @product.images.count > 1 %>
          <div class="flex gap-2 mt-2 overflow-x-auto">
            <% @product.images.each do |img| %>
              <%= image_tag img, class: "h-16 w-16 object-cover rounded border" %>
            <% end %>
          </div>
        <% end %>
      <% else %>
        <div class="w-full h-64 bg-gray-100 rounded-lg flex items-center justify-center">
          <span class="text-8xl text-gray-300">📦</span>
        </div>
      <% end %>
    </div>

    <!-- Details -->
    <div>
      <p class="text-sm text-gray-500 mb-1">
        <%= link_to @store.name, store_path(@store), class: "text-green-700 hover:underline" %>
      </p>
      <h1 class="text-2xl font-bold text-gray-800 mb-2"><%= @product.name %></h1>
      <p class="text-3xl font-bold text-green-700 mb-4">Rs. <%= number_with_delimiter(@product.price) %></p>
      <p class="text-gray-600 text-sm mb-4"><%= @product.description %></p>

      <%= form_with url: add_item_cart_path, method: :post, local: true do |f| %>
        <%= hidden_field_tag :product_id, @product.id %>

        <% if @variants.any? %>
          <div class="mb-4">
            <%= label_tag :product_variant_id, "Select Option", class: "block text-sm font-medium text-gray-700 mb-1" %>
            <%= select_tag :product_variant_id,
                  options_for_select(@variants.map { |v| [v.display_name + " (+Rs. #{v.price_modifier})", v.id] }),
                  class: "border rounded px-3 py-2 text-sm w-full" %>
          </div>
        <% end %>

        <div class="flex items-center space-x-3 mb-4">
          <%= label_tag :quantity, "Qty:", class: "text-sm font-medium" %>
          <%= number_field_tag :quantity, 1, min: 1, max: 99,
                class: "border rounded px-3 py-2 text-sm w-20" %>
        </div>

        <% if @product.in_stock? %>
          <%= f.submit "🛒 Add to Cart",
                class: "w-full bg-green-600 hover:bg-green-700 text-white font-bold py-3 rounded-lg cursor-pointer" %>
        <% else %>
          <button disabled class="w-full bg-gray-300 text-gray-500 font-bold py-3 rounded-lg cursor-not-allowed">
            Out of Stock
          </button>
        <% end %>
      <% end %>
    </div>
  </div>

  <!-- Related products -->
  <% if @related_products.any? %>
    <section class="mt-10">
      <h2 class="text-xl font-bold mb-4">More from <%= @store.name %></h2>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <%= render partial: "product_card", collection: @related_products, as: :product %>
      </div>
    </section>
  <% end %>
</div>
