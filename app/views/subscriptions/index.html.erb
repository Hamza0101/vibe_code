<% content_for :title, "Pricing Plans" %>

<div class="max-w-5xl mx-auto px-4 py-12">
  <div class="text-center mb-10">
    <h1 class="text-3xl font-bold">Choose Your Plan</h1>
    <p class="text-gray-600 mt-2">Start free, upgrade when ready to grow.</p>
    <% if @current_plan %>
      <p class="mt-2 text-green-700 font-medium">Current plan: <strong><%= @current_plan.name %></strong></p>
    <% end %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
    <% @plans.each do |plan| %>
      <div class="bg-white rounded-xl shadow-md overflow-hidden flex flex-col
        <%= @current_plan&.id == plan.id ? 'ring-2 ring-green-500' : '' %>
        <%= plan.slug == 'pro' ? 'transform scale-105 shadow-xl' : '' %>">
        <% if plan.slug == 'pro' %>
          <div class="bg-green-600 text-white text-xs text-center font-bold py-1">MOST POPULAR</div>
        <% end %>
        <div class="p-6 flex-1">
          <h3 class="text-xl font-bold mb-1"><%= plan.name %></h3>
          <div class="text-3xl font-bold text-green-700 mb-1">
            <% if plan.free? %>
              Free
            <% else %>
              Rs. <%= number_with_delimiter(plan.price_pkr) %>
              <span class="text-sm font-normal text-gray-500">/mo</span>
            <% end %>
          </div>
          <ul class="space-y-2 my-4 text-sm text-gray-600">
            <li>✅ <%= plan.product_limit.nil? ? "Unlimited" : plan.product_limit %> Products</li>
            <li><%= plan.feature?("analytics") ? "✅" : "❌" %> Analytics Dashboard</li>
            <li><%= plan.feature?("featured") ? "✅" : "❌" %> Featured Listing</li>
            <li><%= plan.feature?("sms") ? "✅" : "❌" %> SMS Alerts</li>
            <li><%= plan.feature?("bulk_import") ? "✅" : "❌" %> Bulk Import</li>
          </ul>
        </div>
        <div class="p-4 border-t">
          <% if @current_plan&.id == plan.id %>
            <button disabled class="w-full bg-gray-200 text-gray-500 py-2 rounded font-medium text-sm">Current Plan</button>
          <% elsif plan.slug == 'enterprise' %>
            <a href="mailto:sales@bazaarpk.com" class="block w-full text-center bg-gray-800 hover:bg-gray-700 text-white py-2 rounded font-medium text-sm">
              Contact Sales
            </a>
          <% else %>
            <%= button_to "Select Plan", subscriptions_path, method: :post,
                  params: { plan_id: plan.id },
                  class: "w-full #{plan.slug == 'pro' ? 'bg-green-600 hover:bg-green-700' : 'bg-gray-800 hover:bg-gray-700'} text-white py-2 rounded font-medium text-sm cursor-pointer" %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <p class="text-center text-sm text-gray-500 mt-8">
    For JazzCash / EasyPaisa payments, please contact us at
    <a href="mailto:support@bazaarpk.com" class="text-green-700 hover:underline">support@bazaarpk.com</a>
  </p>
</div>
