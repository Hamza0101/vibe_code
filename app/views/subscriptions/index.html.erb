<% content_for :title, "Pricing Plans" %>

<div class="max-w-6xl mx-auto px-4 py-16">
  <!-- Header -->
  <div class="text-center mb-14">
    <h1 class="text-4xl font-bold text-slate-900 tracking-tight mb-3">Simple, Transparent Pricing</h1>
    <p class="text-slate-500 text-lg max-w-xl mx-auto">Start for free, scale as you grow. No hidden fees.</p>
    <% if @current_plan %>
      <div class="inline-flex items-center gap-2 mt-4 bg-green-50 border border-green-200 text-green-800 px-4 py-2 rounded-full text-sm font-semibold">
        <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
        Current plan: <%= @current_plan.name %>
      </div>
    <% end %>
  </div>

  <!-- Plans Grid -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 items-start">
    <% @plans.each do |plan| %>
      <div class="relative bg-white rounded-2xl border-2 flex flex-col transition-all duration-200
        <%= plan.slug == 'pro' ? 'border-green-500 shadow-xl shadow-green-100 scale-[1.02]' : 'border-slate-200 shadow-sm hover:shadow-md hover:border-slate-300' %>
        <%= @current_plan&.id == plan.id ? '!border-green-500' : '' %>">

        <% if plan.slug == 'pro' %>
          <div class="absolute -top-3.5 inset-x-0 flex justify-center">
            <span class="bg-green-600 text-white text-xs font-bold px-4 py-1 rounded-full shadow">MOST POPULAR</span>
          </div>
        <% end %>

        <div class="p-6 flex-1">
          <!-- Plan name + price -->
          <div class="mb-5">
            <h3 class="text-lg font-bold text-slate-900 mb-2"><%= plan.name %></h3>
            <% if plan.free? %>
              <div class="text-4xl font-black text-slate-900">Free</div>
              <p class="text-slate-400 text-sm mt-0.5">Forever</p>
            <% elsif plan.slug == 'enterprise' %>
              <div class="text-3xl font-black text-slate-900">Custom</div>
              <p class="text-slate-400 text-sm mt-0.5">Contact us for pricing</p>
            <% else %>
              <div class="flex items-end gap-1">
                <span class="text-4xl font-black text-slate-900">Rs. <%= number_with_delimiter(plan.price_pkr) %></span>
              </div>
              <p class="text-slate-400 text-sm mt-0.5">per month</p>
            <% end %>
          </div>

          <!-- Divider -->
          <div class="border-t border-slate-100 my-4"></div>

          <!-- Features -->
          <ul class="space-y-3 text-sm">
            <li class="flex items-center gap-2.5">
              <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
              <span class="text-slate-700 font-medium"><%= plan.product_limit.nil? ? "Unlimited" : plan.product_limit %> products</span>
            </li>
            <li class="flex items-center gap-2.5">
              <% if plan.feature?("analytics") %>
                <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                <span class="text-slate-700">Analytics dashboard</span>
              <% else %>
                <svg class="w-4 h-4 text-slate-300 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                <span class="text-slate-400">Analytics dashboard</span>
              <% end %>
            </li>
            <li class="flex items-center gap-2.5">
              <% if plan.feature?("featured") %>
                <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                <span class="text-slate-700">Featured listing</span>
              <% else %>
                <svg class="w-4 h-4 text-slate-300 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                <span class="text-slate-400">Featured listing</span>
              <% end %>
            </li>
            <li class="flex items-center gap-2.5">
              <% if plan.feature?("sms") %>
                <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                <span class="text-slate-700">SMS notifications</span>
              <% else %>
                <svg class="w-4 h-4 text-slate-300 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                <span class="text-slate-400">SMS notifications</span>
              <% end %>
            </li>
            <li class="flex items-center gap-2.5">
              <% if plan.feature?("bulk_import") %>
                <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
                <span class="text-slate-700">Bulk product import</span>
              <% else %>
                <svg class="w-4 h-4 text-slate-300 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/></svg>
                <span class="text-slate-400">Bulk product import</span>
              <% end %>
            </li>
          </ul>
        </div>

        <!-- CTA -->
        <div class="p-5 border-t border-slate-100">
          <% if @current_plan&.id == plan.id %>
            <div class="w-full text-center py-2.5 text-sm font-semibold text-green-700 bg-green-50 rounded-xl border border-green-200">
              ✓ Current Plan
            </div>
          <% elsif plan.slug == 'enterprise' %>
            <a href="mailto:sales@bazaarpk.com"
               class="block w-full text-center bg-slate-900 hover:bg-slate-800 text-white py-2.5 rounded-xl font-semibold text-sm transition">
              Contact Sales
            </a>
          <% elsif plan.free? %>
            <% if user_signed_in? && current_user.vendor? %>
              <%= button_to "Select Free Plan", subscriptions_path, method: :post,
                    params: { plan_id: plan.id },
                    class: "w-full border border-slate-300 hover:bg-slate-50 text-slate-700 py-2.5 rounded-xl font-semibold text-sm cursor-pointer transition" %>
            <% else %>
              <%= link_to "Get Started Free", new_user_registration_path(role: "vendor"),
                    class: "block w-full text-center border border-slate-300 hover:bg-slate-50 text-slate-700 py-2.5 rounded-xl font-semibold text-sm transition" %>
            <% end %>
          <% else %>
            <%= button_to "Upgrade to #{plan.name}", subscriptions_path, method: :post,
                  params: { plan_id: plan.id },
                  class: "w-full #{ plan.slug == 'pro' ? 'bg-green-600 hover:bg-green-700' : 'bg-slate-900 hover:bg-slate-800' } text-white py-2.5 rounded-xl font-semibold text-sm cursor-pointer transition shadow-sm" %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <p class="text-center text-sm text-slate-400 mt-10">
    JazzCash / EasyPaisa payments? Contact us at
    <a href="mailto:support@bazaarpk.com" class="text-green-700 hover:text-green-800 font-medium">support@bazaarpk.com</a>
  </p>
</div>
