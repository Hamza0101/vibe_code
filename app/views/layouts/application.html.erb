<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <title><%= content_for?(:title) ? yield(:title) + " — " : "" %>BazaarPK</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-50 text-slate-900 font-sans antialiased">
    <%= render "shared/navbar" %>

    <div id="flash-messages" class="max-w-7xl mx-auto px-4 pt-3 space-y-2">
      <% if notice.present? %>
        <div class="flex items-center gap-3 bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-xl text-sm font-medium shadow-sm" role="alert">
          <svg class="w-5 h-5 text-emerald-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          <%= notice %>
        </div>
      <% end %>
      <% if alert.present? %>
        <div class="flex items-center gap-3 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-xl text-sm font-medium shadow-sm" role="alert">
          <svg class="w-5 h-5 text-red-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
          <%= alert %>
        </div>
      <% end %>
    </div>

    <div id="cart-flash" class="max-w-7xl mx-auto px-4"></div>

    <main class="min-h-screen">
      <%= yield %>
    </main>

    <%= render "shared/footer" %>
  </body>
</html>
