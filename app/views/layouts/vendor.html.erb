<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for?(:title) ? yield(:title) + " | " : "" %>Vendor Dashboard — BazaarPK</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100 text-gray-900 font-sans">
    <div class="flex h-screen overflow-hidden">
      <!-- Sidebar -->
      <aside class="w-64 bg-green-800 text-white flex flex-col">
        <div class="p-4 border-b border-green-700">
          <a href="/" class="text-xl font-bold text-white">🛒 BazaarPK</a>
          <p class="text-green-300 text-sm mt-1">Vendor Panel</p>
        </div>
        <nav class="flex-1 p-4 space-y-1">
          <%= link_to "Dashboard", vendor_root_path, class: "flex items-center px-3 py-2 rounded text-green-100 hover:bg-green-700" %>
          <%= link_to "My Store", vendor_store_path, class: "flex items-center px-3 py-2 rounded text-green-100 hover:bg-green-700" %>
          <%= link_to "Products", vendor_products_path, class: "flex items-center px-3 py-2 rounded text-green-100 hover:bg-green-700" %>
          <%= link_to "Orders", vendor_orders_path, class: "flex items-center px-3 py-2 rounded text-green-100 hover:bg-green-700" %>
          <%= link_to "Subscription", subscriptions_path, class: "flex items-center px-3 py-2 rounded text-green-100 hover:bg-green-700" %>
        </nav>
        <div class="p-4 border-t border-green-700">
          <%= link_to "View Storefront", root_path, class: "block text-green-300 text-sm hover:text-white" %>
          <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "block text-green-300 text-sm hover:text-white mt-1" %>
        </div>
      </aside>

      <!-- Main content -->
      <div class="flex-1 flex flex-col overflow-hidden">
        <header class="bg-white shadow px-6 py-4 flex items-center justify-between">
          <h1 class="text-xl font-semibold"><%= content_for?(:page_title) ? yield(:page_title) : "Dashboard" %></h1>
          <span class="text-sm text-gray-500"><%= current_user.name || current_user.email %></span>
        </header>

        <% if notice.present? %>
          <div class="bg-green-100 border-l-4 border-green-500 text-green-700 px-4 py-3 mx-4 mt-2 rounded">
            <%= notice %>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="bg-red-100 border-l-4 border-red-500 text-red-700 px-4 py-3 mx-4 mt-2 rounded">
            <%= alert %>
          </div>
        <% end %>

        <main class="flex-1 overflow-y-auto p-6">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
