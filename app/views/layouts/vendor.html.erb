<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for?(:page_title) ? yield(:page_title) + " — " : "" %>Vendor Dashboard — BazaarPK</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-50 text-slate-900 antialiased" style="font-family: 'Inter', ui-sans-serif, system-ui, sans-serif;">
    <div class="flex h-screen overflow-hidden">

      <!-- Sidebar -->
      <aside class="w-64 bg-white border-r border-slate-200 flex flex-col flex-shrink-0">

        <!-- Logo section -->
        <div class="px-5 py-4 border-b border-slate-100 flex-shrink-0">
          <a href="/" class="flex items-center gap-2.5 group">
            <div class="w-8 h-8 rounded-xl flex items-center justify-center flex-shrink-0 shadow-sm" style="background: linear-gradient(135deg, #16a34a 0%, #15803d 100%);">
              <span class="text-white font-black text-sm tracking-tighter">B</span>
            </div>
            <div>
              <span class="font-black text-slate-900 tracking-tight leading-none text-[15px]">BazaarPK</span>
              <span class="block text-[10px] font-medium text-slate-400 leading-tight tracking-wide">Vendor Portal</span>
            </div>
          </a>
        </div>

        <!-- User / store section -->
        <div class="px-4 py-3.5 border-b border-slate-100 flex-shrink-0">
          <div class="flex items-center gap-3">
            <div class="w-9 h-9 rounded-xl flex items-center justify-center text-sm font-bold text-green-700 flex-shrink-0" style="background: linear-gradient(135deg, #dcfce7 0%, #bbf7d0 100%);">
              <%= current_user.name&.first&.upcase || "V" %>
            </div>
            <div class="min-w-0 flex-1">
              <p class="text-sm font-semibold text-slate-800 leading-tight truncate">
                <%= current_user.name || current_user.email.split("@").first %>
              </p>
              <% if current_user.store.present? %>
                <p class="text-xs text-slate-400 leading-tight truncate mt-0.5"><%= current_user.store.name %></p>
              <% else %>
                <p class="text-xs text-slate-400 leading-tight mt-0.5">Vendor Account</p>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Navigation -->
        <nav class="flex-1 p-3 space-y-0.5 overflow-y-auto">
          <% nav_items = [
            { path: vendor_root_path,     label: "Dashboard",    icon: "M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" },
            { path: vendor_store_path,    label: "My Store",     icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" },
            { path: vendor_products_path, label: "Products",     icon: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" },
            { path: vendor_orders_path,   label: "Orders",       icon: "M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" },
            { path: vendor_analytics_path, label: "Analytics",   icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" },
            { path: subscriptions_path,   label: "Subscription", icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" },
          ] %>
          <% nav_items.each do |item| %>
            <% is_active = request.path.start_with?(item[:path].split('?').first) && (item[:path] == vendor_root_path ? request.path == vendor_root_path : true) %>
            <%= link_to item[:path],
                  class: "flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150 #{ is_active ? 'bg-green-50 text-green-700 border-l-2 border-green-600 pl-[10px]' : 'text-slate-500 hover:bg-slate-50 hover:text-slate-900 border-l-2 border-transparent pl-[10px]' }" do %>
              <% if is_active %>
                <span class="w-1.5 h-1.5 rounded-full bg-green-500 flex-shrink-0 -ml-0.5"></span>
              <% else %>
                <span class="w-1.5 h-1.5 rounded-full flex-shrink-0 -ml-0.5"></span>
              <% end %>
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="<%= item[:icon] %>"/>
              </svg>
              <%= item[:label] %>
            <% end %>
          <% end %>
        </nav>

        <!-- POS Button -->
        <div class="px-3 pb-3 flex-shrink-0">
          <%= link_to vendor_pos_path, target: "_blank",
                class: "flex items-center justify-center gap-2.5 w-full px-3 py-3 rounded-xl text-sm font-bold text-white transition-all duration-150 shadow-sm hover:shadow-md hover:-translate-y-px active:scale-[0.98]",
                style: "background: linear-gradient(135deg, #16a34a 0%, #15803d 100%); box-shadow: 0 2px 8px 0 rgb(22 163 74 / 0.30);" do %>
            <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            Open POS Terminal
            <svg class="w-3 h-3 opacity-70 ml-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          <% end %>
        </div>

        <!-- Footer actions -->
        <div class="p-3 border-t border-slate-100 space-y-0.5 flex-shrink-0">
          <%= link_to root_path, class: "flex items-center gap-2.5 px-3 py-2.5 rounded-xl text-xs font-medium text-slate-400 hover:text-slate-700 hover:bg-slate-50 transition-all duration-150" do %>
            <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            View Storefront
          <% end %>
          <%= button_to destroy_user_session_path, method: :delete,
                class: "w-full flex items-center gap-2.5 px-3 py-2.5 rounded-xl text-xs font-medium text-slate-400 hover:text-red-600 hover:bg-red-50 transition-all duration-150 cursor-pointer" do %>
            <svg class="w-3.5 h-3.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
            </svg>
            Sign Out
          <% end %>
        </div>

      </aside>

      <!-- Main content area -->
      <div class="flex-1 flex flex-col overflow-hidden">

        <!-- Top bar -->
        <header class="border-b border-slate-200/80 px-6 py-3.5 flex items-center justify-between flex-shrink-0" style="background: linear-gradient(to right, #ffffff, rgb(248 250 252 / 0.8));">
          <div>
            <h1 class="text-[15px] font-bold text-slate-900 leading-tight">
              <%= content_for?(:page_title) ? yield(:page_title) : "Dashboard" %>
            </h1>
            <% if content_for?(:page_subtitle) %>
              <p class="text-xs text-slate-400 mt-0.5"><%= yield(:page_subtitle) %></p>
            <% end %>
          </div>
          <div class="flex items-center gap-3">
            <span class="hidden sm:flex items-center gap-1.5 text-xs text-slate-400 font-medium bg-slate-50 border border-slate-200 px-3 py-1.5 rounded-lg">
              <svg class="w-3 h-3 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
              <%= Date.today.strftime("%b %d, %Y") %>
            </span>
          </div>
        </header>

        <!-- Flash messages -->
        <% if notice.present? %>
          <div class="mx-5 mt-4 flash-success">
            <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
            <%= notice %>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="mx-5 mt-4 flash-error">
            <svg class="w-4 h-4 text-red-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
            </svg>
            <%= alert %>
          </div>
        <% end %>

        <main class="flex-1 overflow-y-auto p-6">
          <%= yield %>
        </main>

      </div>
    </div>
  </body>
</html>
