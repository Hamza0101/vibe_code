<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for?(:title) ? yield(:title) + " | " : "" %>Admin — BazaarPK</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-100 text-gray-900 font-sans">
    <div class="flex h-screen overflow-hidden">
      <aside class="w-64 bg-gray-900 text-white flex flex-col">
        <div class="p-4 border-b border-gray-700">
          <a href="/" class="text-xl font-bold text-white">🛒 BazaarPK</a>
          <p class="text-gray-400 text-sm mt-1">Admin Panel</p>
        </div>
        <nav class="flex-1 p-4 space-y-1">
          <%= link_to "Dashboard", admin_root_path, class: "block px-3 py-2 rounded text-gray-300 hover:bg-gray-700" %>
          <%= link_to "Stores", admin_stores_path, class: "block px-3 py-2 rounded text-gray-300 hover:bg-gray-700" %>
          <%= link_to "Users", admin_users_path, class: "block px-3 py-2 rounded text-gray-300 hover:bg-gray-700" %>
          <%= link_to "Categories", admin_categories_path, class: "block px-3 py-2 rounded text-gray-300 hover:bg-gray-700" %>
          <%= link_to "Plans", admin_subscription_plans_path, class: "block px-3 py-2 rounded text-gray-300 hover:bg-gray-700" %>
        </nav>
        <div class="p-4 border-t border-gray-700">
          <%= button_to "Sign Out", destroy_user_session_path, method: :delete, class: "text-gray-400 text-sm hover:text-white" %>
        </div>
      </aside>

      <div class="flex-1 flex flex-col overflow-hidden">
        <header class="bg-white shadow px-6 py-4 flex items-center justify-between">
          <h1 class="text-xl font-semibold"><%= content_for?(:page_title) ? yield(:page_title) : "Admin" %></h1>
          <span class="text-sm text-gray-500"><%= current_user.email %></span>
        </header>

        <% if notice.present? %>
          <div class="bg-green-100 border-l-4 border-green-500 text-green-700 px-4 py-3 mx-4 mt-2 rounded">
            <%= notice %>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="bg-red-100 border-l-4 border-red-500 text-red-700 px-4 py-3 mx-4 mt-2 rounded">
            <%= alert %>
          </div>
        <% end %>

        <main class="flex-1 overflow-y-auto p-6">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
