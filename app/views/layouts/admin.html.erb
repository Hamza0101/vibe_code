<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for?(:page_title) ? yield(:page_title) + " — " : "" %>Admin — BazaarPK</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta charset="utf-8">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-100 text-slate-900 font-sans antialiased">
    <div class="flex h-screen overflow-hidden">

      <!-- Sidebar -->
      <aside class="w-60 bg-slate-900 text-white flex flex-col flex-shrink-0">
        <!-- Logo -->
        <div class="p-5 border-b border-slate-800">
          <a href="/" class="flex items-center gap-2">
            <div class="w-7 h-7 bg-green-500 rounded-lg flex items-center justify-center text-white font-bold text-xs">B</div>
            <span class="font-bold text-white tracking-tight">BazaarPK</span>
          </a>
          <p class="text-slate-500 text-xs mt-1 font-medium">Admin Panel</p>
        </div>

        <!-- Nav -->
        <nav class="flex-1 p-3 space-y-0.5 overflow-y-auto">
          <% admin_nav = [
            { path: admin_root_path, label: "Dashboard", icon: "M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" },
            { path: admin_stores_path, label: "Stores", icon: "M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" },
            { path: admin_users_path, label: "Users", icon: "M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" },
            { path: admin_categories_path, label: "Categories", icon: "M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" },
            { path: admin_subscription_plans_path, label: "Plans", icon: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" },
          ] %>
          <% admin_nav.each do |item| %>
            <%= link_to item[:path],
                  class: "flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium transition #{ request.path.start_with?(item[:path].split('?').first) && (item[:path] == admin_root_path ? request.path == admin_root_path : true) ? 'bg-white/10 text-white' : 'text-slate-400 hover:bg-white/5 hover:text-white' }" do %>
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="<%= item[:icon] %>"/>
              </svg>
              <%= item[:label] %>
            <% end %>
          <% end %>
        </nav>

        <!-- Footer -->
        <div class="p-3 border-t border-slate-800 space-y-1">
          <div class="px-3 py-2">
            <p class="text-xs text-slate-400 font-medium truncate"><%= current_user.email %></p>
          </div>
          <%= button_to destroy_user_session_path, method: :delete,
                class: "w-full flex items-center gap-2 px-3 py-2 rounded-xl text-xs text-slate-500 hover:text-red-400 hover:bg-red-900/20 transition font-medium" do %>
            <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
            Sign Out
          <% end %>
        </div>
      </aside>

      <!-- Main -->
      <div class="flex-1 flex flex-col overflow-hidden">
        <header class="bg-white border-b border-slate-200 px-6 py-4 flex items-center justify-between flex-shrink-0">
          <h1 class="text-lg font-bold text-slate-900"><%= content_for?(:page_title) ? yield(:page_title) : "Admin" %></h1>
          <span class="text-xs text-slate-400 font-medium hidden sm:block"><%= Date.today.strftime("%A, %B %d, %Y") %></span>
        </header>

        <% if notice.present? %>
          <div class="mx-4 mt-3 flex items-center gap-3 bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-xl text-sm font-medium">
            <svg class="w-4 h-4 text-emerald-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            <%= notice %>
          </div>
        <% end %>
        <% if alert.present? %>
          <div class="mx-4 mt-3 flex items-center gap-3 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-xl text-sm font-medium">
            <svg class="w-4 h-4 text-red-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/></svg>
            <%= alert %>
          </div>
        <% end %>

        <main class="flex-1 overflow-y-auto p-6">
          <%= yield %>
        </main>
      </div>
    </div>
  </body>
</html>
