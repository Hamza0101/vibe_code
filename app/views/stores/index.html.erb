<% content_for :title, "Browse Stores" %>

<div class="max-w-7xl mx-auto px-4 py-10">
  <!-- Header -->
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-slate-900 tracking-tight">Browse Stores</h1>
    <p class="text-slate-500 mt-1">Discover local businesses near you</p>
  </div>

  <!-- Filters -->
  <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-5 mb-8">
    <%= form_with url: stores_path, method: :get, class: "flex flex-wrap gap-4 items-end" do |f| %>
      <div class="flex-1 min-w-36">
        <%= f.label :category, "Category", class: "block text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1.5" %>
        <%= f.select :category,
              [["All Categories", ""], ["Grocery", "grocery"], ["Pharmacy", "pharmacy"], ["Clothing", "clothing"], ["Electronics", "electronics"], ["Food", "food"], ["Home & Living", "home"]],
              { selected: params[:category] },
              class: "w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent" %>
      </div>
      <div class="flex-1 min-w-36">
        <%= f.label :city, "City", class: "block text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1.5" %>
        <%= f.select :city,
              [["All Cities", ""]] + @cities.map { |c| [c, c] },
              { selected: params[:city] },
              class: "w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:border-transparent" %>
      </div>
      <div class="flex gap-2 pb-0.5">
        <%= f.submit "Apply Filters", class: "bg-green-600 hover:bg-green-700 text-white px-5 py-2.5 rounded-xl text-sm font-semibold cursor-pointer transition shadow-sm" %>
        <%= link_to "Clear", stores_path, class: "text-slate-500 hover:text-slate-700 text-sm px-4 py-2.5 rounded-xl hover:bg-slate-100 transition font-medium" %>
      </div>
    <% end %>
  </div>

  <!-- Active filters -->
  <% if params[:category].present? || params[:city].present? %>
    <div class="flex items-center gap-2 mb-5 flex-wrap">
      <span class="text-xs text-slate-500 font-medium">Filters:</span>
      <% if params[:category].present? %>
        <span class="inline-flex items-center gap-1 bg-green-100 text-green-700 text-xs font-semibold px-3 py-1 rounded-full">
          <%= params[:category].humanize %>
          <%= link_to stores_path(city: params[:city]), class: "ml-1 hover:text-green-900" do %>&times;<% end %>
        </span>
      <% end %>
      <% if params[:city].present? %>
        <span class="inline-flex items-center gap-1 bg-blue-100 text-blue-700 text-xs font-semibold px-3 py-1 rounded-full">
          <%= params[:city] %>
          <%= link_to stores_path(category: params[:category]), class: "ml-1 hover:text-blue-900" do %>&times;<% end %>
        </span>
      <% end %>
    </div>
  <% end %>

  <!-- Store grid -->
  <% if @stores.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
      <%= render partial: "store_card", collection: @stores, as: :store %>
    </div>
    <div class="mt-8 flex justify-center">
      <%== pagy_nav(@pagy) %>
    </div>
  <% else %>
    <div class="text-center py-24">
      <div class="w-16 h-16 bg-slate-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
      </div>
      <h3 class="text-lg font-semibold text-slate-700 mb-1">No stores found</h3>
      <p class="text-slate-400 text-sm mb-6">Try adjusting your filters or browse all stores</p>
      <%= link_to "Browse All Stores", stores_path, class: "btn-primary" %>
    </div>
  <% end %>
</div>
