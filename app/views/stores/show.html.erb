<% content_for :title, @store.name %>

<div class="max-w-7xl mx-auto px-4 py-8">
  <!-- Store Header Card -->
  <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden mb-8">
    <!-- Banner -->
    <div class="h-48 md:h-56 relative overflow-hidden bg-gradient-to-br
      <%= @store.grocery? ? 'from-green-500 to-emerald-600' : @store.pharmacy? ? 'from-blue-500 to-blue-600' : 'from-purple-500 to-pink-500' %>">
      <% if @store.banner.attached? %>
        <%= image_tag @store.banner, class: "w-full h-full object-cover absolute inset-0" %>
        <div class="absolute inset-0 bg-black/30"></div>
      <% end %>
    </div>

    <!-- Store Info -->
    <div class="px-6 pb-6 relative">
      <!-- Logo -->
      <div class="-mt-8 mb-4">
        <% if @store.logo.attached? %>
          <%= image_tag @store.logo, class: "w-16 h-16 rounded-2xl border-4 border-white shadow-md object-cover" %>
        <% else %>
          <div class="w-16 h-16 rounded-2xl border-4 border-white shadow-md bg-white flex items-center justify-center text-3xl">
            <%= @store.grocery? ? "🥦" : @store.pharmacy? ? "💊" : "👗" %>
          </div>
        <% end %>
      </div>

      <div class="flex flex-col md:flex-row md:items-start justify-between gap-4">
        <div>
          <div class="flex items-center gap-3 flex-wrap">
            <h1 class="text-2xl font-bold text-slate-900"><%= @store.name %></h1>
            <% if @store.featured? %>
              <span class="bg-amber-100 text-amber-700 text-xs font-bold px-2.5 py-1 rounded-full">Featured</span>
            <% end %>
            <span class="text-xs px-2.5 py-1 rounded-full font-medium
              <%= @store.grocery? ? 'bg-green-100 text-green-700' : @store.pharmacy? ? 'bg-blue-100 text-blue-700' : 'bg-purple-100 text-purple-700' %>">
              <%= @store.category.humanize %>
            </span>
          </div>
          <div class="flex items-center gap-4 mt-2 text-sm text-slate-500 flex-wrap">
            <span class="flex items-center gap-1">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <%= @store.city %>
            </span>
            <% if @store.phone.present? %>
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                <%= @store.phone %>
              </span>
            <% end %>
            <% if @avg_rating > 0 %>
              <span class="flex items-center gap-1">
                <svg class="w-4 h-4 text-amber-400 fill-amber-400" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                <%= @avg_rating %> rating
              </span>
            <% end %>
          </div>
          <% if @store.description.present? %>
            <p class="text-slate-600 text-sm mt-3 max-w-2xl leading-relaxed"><%= @store.description %></p>
          <% end %>
        </div>
      </div>
    </div>
  </div>

  <!-- Products section -->
  <div class="grid grid-cols-12 gap-6">
    <!-- Categories sidebar -->
    <aside class="col-span-12 md:col-span-3">
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-4 sticky top-20">
        <h3 class="text-xs font-bold text-slate-500 uppercase tracking-wider mb-3">Categories</h3>
        <%= link_to "All Products", store_path(@store),
              class: "block text-sm font-medium text-green-700 hover:text-green-900 py-2 px-3 rounded-xl bg-green-50 mb-1" %>
        <% @categories.each do |name, slug| %>
          <%= link_to name, store_path(@store, "q[category_slug_eq]": slug),
                class: "block text-sm text-slate-600 hover:text-green-700 hover:bg-slate-50 py-2 px-3 rounded-xl transition" %>
        <% end %>
      </div>
    </aside>

    <!-- Products grid -->
    <main class="col-span-12 md:col-span-9">
      <% if @products.any? %>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          <%= render partial: "/products/product_card", collection: @products, as: :product %>
        </div>
        <div class="mt-6 flex justify-center"><%== pagy_nav(@pagy) %></div>
      <% else %>
        <div class="text-center py-20 bg-white rounded-2xl border border-slate-200">
          <p class="text-5xl mb-4">📦</p>
          <h3 class="text-lg font-semibold text-slate-700 mb-1">No products yet</h3>
          <p class="text-slate-400 text-sm">This store hasn't listed any products.</p>
        </div>
      <% end %>
    </main>
  </div>

  <!-- Reviews -->
  <% if @reviews.any? %>
    <section class="mt-10">
      <h2 class="text-xl font-bold text-slate-900 mb-5">Customer Reviews</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <% @reviews.each do |review| %>
          <div class="bg-white rounded-2xl border border-slate-200 p-5 shadow-sm">
            <div class="flex items-center justify-between mb-3">
              <span class="font-semibold text-sm text-slate-800"><%= review.user&.name.presence || review.user&.email&.split("@")&.first || "Customer" %></span>
              <div class="flex text-amber-400">
                <% review.rating.times do %><span>★</span><% end %>
                <% (5 - review.rating).times do %><span class="text-slate-200">★</span><% end %>
              </div>
            </div>
            <p class="text-slate-600 text-sm leading-relaxed"><%= review.body %></p>
          </div>
        <% end %>
      </div>
    </section>
  <% end %>

  <!-- Write review -->
  <% if user_signed_in? && current_user.customer? %>
    <section class="mt-6 bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
      <h3 class="font-bold text-slate-900 mb-4">Write a Review</h3>
      <%= form_with url: reviews_path, method: :post do |f| %>
        <%= hidden_field_tag :store_id, @store.id %>
        <div class="flex items-center gap-4 mb-4">
          <%= f.label :rating, "Rating", class: "text-sm font-medium text-slate-700" %>
          <%= f.select :rating, (1..5).map { |n| ["#{n} ★", n] }, { include_blank: "Select..." },
                { name: "review[rating]", class: "border border-slate-200 rounded-xl px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" } %>
        </div>
        <%= f.text_area :body, name: "review[body]", placeholder: "Share your experience with this store...",
              class: "w-full border border-slate-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 resize-none", rows: 3 %>
        <%= f.submit "Submit Review", class: "mt-3 bg-green-600 hover:bg-green-700 text-white px-6 py-2.5 rounded-xl text-sm font-semibold cursor-pointer transition shadow-sm" %>
      <% end %>
    </section>
  <% end %>
</div>
