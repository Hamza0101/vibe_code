<% content_for :title, @store.name %>

<div class="max-w-7xl mx-auto px-4 py-8">
  <!-- Store header -->
  <div class="bg-white rounded-xl shadow overflow-hidden mb-8">
    <div class="h-40 bg-gradient-to-r from-green-600 to-green-500 flex items-center justify-center relative">
      <% if @store.banner.attached? %>
        <%= image_tag @store.banner, class: "h-full w-full object-cover absolute inset-0" %>
      <% end %>
      <div class="relative z-10 text-center text-white">
        <% if @store.logo.attached? %>
          <%= image_tag @store.logo, class: "h-16 w-16 rounded-full border-4 border-white mx-auto mb-2" %>
        <% else %>
          <div class="text-6xl mb-2"><%= @store.grocery? ? "🥦" : @store.pharmacy? ? "💊" : "👗" %></div>
        <% end %>
        <h1 class="text-2xl font-bold drop-shadow"><%= @store.name %></h1>
        <p class="text-green-100"><%= @store.city %> · <%= @store.category.humanize %></p>
      </div>
    </div>
    <div class="p-4 flex items-center justify-between">
      <p class="text-gray-600 text-sm"><%= @store.description %></p>
      <div class="flex items-center space-x-4 text-sm text-gray-500">
        <span>📞 <%= @store.phone || "N/A" %></span>
        <span>⭐ <%= @avg_rating > 0 ? @avg_rating : "No reviews" %></span>
      </div>
    </div>
  </div>

  <!-- Products section -->
  <div class="grid grid-cols-12 gap-6">
    <!-- Categories sidebar -->
    <aside class="col-span-12 md:col-span-3">
      <div class="bg-white rounded-xl shadow p-4">
        <h3 class="font-semibold mb-3">Categories</h3>
        <%= link_to "All Products", store_path(@store), class: "block text-sm text-green-700 hover:text-green-900 py-1" %>
        <% @categories.each do |name, slug| %>
          <%= link_to name, store_path(@store, "q[category_slug_eq]": slug),
                class: "block text-sm text-gray-600 hover:text-green-700 py-1" %>
        <% end %>
      </div>
    </aside>

    <!-- Products grid -->
    <main class="col-span-12 md:col-span-9">
      <% if @products.any? %>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          <%= render partial: "/products/product_card", collection: @products, as: :product %>
        </div>
        <div class="mt-6"><%== pagy_nav(@pagy) %></div>
      <% else %>
        <div class="text-center py-12 text-gray-500">
          <p class="text-4xl mb-2">📦</p>
          <p>No products listed yet.</p>
        </div>
      <% end %>
    </main>
  </div>

  <!-- Reviews -->
  <% if @reviews.any? %>
    <section class="mt-10 bg-white rounded-xl shadow p-6">
      <h2 class="text-xl font-bold mb-4">Customer Reviews</h2>
      <% @reviews.each do |review| %>
        <div class="border-b pb-4 mb-4 last:border-b-0">
          <div class="flex items-center justify-between">
            <span class="font-medium text-sm"><%= review.user.name || review.user.email %></span>
            <span class="text-yellow-500 text-sm"><%= review.star_display %></span>
          </div>
          <p class="text-gray-600 text-sm mt-1"><%= review.body %></p>
        </div>
      <% end %>
    </section>
  <% end %>

  <!-- Write review -->
  <% if user_signed_in? && current_user.customer? %>
    <section class="mt-6 bg-white rounded-xl shadow p-6">
      <h3 class="font-semibold mb-3">Write a Review</h3>
      <%= form_with url: reviews_path, method: :post do |f| %>
        <%= hidden_field_tag :store_id, @store.id %>
        <div class="flex items-center space-x-2 mb-3">
          <%= f.label :rating, "Rating", class: "text-sm font-medium" %>
          <%= f.select :rating, (1..5).map { |n| ["#{n} ★", n] }, { include_blank: "Select..." },
                { name: "review[rating]", class: "border rounded px-2 py-1 text-sm" } %>
        </div>
        <%= f.text_area :body, name: "review[body]", placeholder: "Write your review...",
              class: "w-full border rounded px-3 py-2 text-sm", rows: 3 %>
        <%= f.submit "Submit Review", class: "mt-2 bg-green-600 text-white px-4 py-2 rounded text-sm hover:bg-green-700 cursor-pointer" %>
      <% end %>
    </section>
  <% end %>
</div>
