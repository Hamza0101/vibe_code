<div class="group relative bg-white rounded-2xl border border-slate-200 overflow-hidden hover:border-green-300 hover:-translate-y-1 hover:shadow-lg transition-all duration-200 flex flex-col">
  <!-- Full card link overlay -->
  <%= link_to store_path(store), class: "absolute inset-0 z-10", aria: { label: store.name } do %><% end %>

  <!-- Banner -->
  <div class="h-36 relative overflow-hidden
    <%= store.grocery? ? 'bg-gradient-to-br from-green-400 to-emerald-600' : store.pharmacy? ? 'bg-gradient-to-br from-blue-400 to-blue-600' : store.respond_to?(:electronics?) && store.electronics? ? 'bg-gradient-to-br from-amber-400 to-orange-500' : 'bg-gradient-to-br from-violet-500 to-purple-700' %>">
    <% if store.banner.attached? %>
      <%= image_tag store.banner, class: "w-full h-full object-cover absolute inset-0 group-hover:scale-105 transition-transform duration-700" %>
      <div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent"></div>
    <% else %>
      <!-- Subtle grid pattern overlay -->
      <div class="absolute inset-0" style="background-image: linear-gradient(rgba(255,255,255,0.08) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.08) 1px, transparent 1px); background-size: 24px 24px;"></div>
      <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
    <% end %>

    <!-- Featured badge -->
    <% if store.featured? %>
      <span class="absolute top-3 right-3 z-20 inline-flex items-center gap-1 bg-amber-400 text-amber-900 text-xs font-bold px-2.5 py-1 rounded-full shadow-sm">
        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
        Featured
      </span>
    <% end %>

    <!-- Store logo -->
    <div class="absolute -bottom-5 left-4 z-20">
      <div class="relative">
        <% if store.logo.attached? %>
          <%= image_tag store.logo, class: "w-12 h-12 rounded-xl border-2 border-white shadow-md object-cover ring-1 ring-slate-100" %>
        <% else %>
          <div class="w-12 h-12 bg-white rounded-xl border-2 border-white shadow-md ring-1 ring-slate-100 flex items-center justify-center">
            <% if store.grocery? %>
              <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/></svg>
            <% elsif store.pharmacy? %>
              <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            <% else %>
              <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Content -->
  <div class="pt-9 pb-4 px-4 flex-1 flex flex-col">
    <!-- Name + verified -->
    <div class="flex items-center gap-1.5 mb-1">
      <h3 class="font-bold text-slate-900 text-sm leading-snug group-hover:text-green-700 transition-colors duration-150 line-clamp-1"><%= store.name %></h3>
      <% if store.respond_to?(:verified?) && store.verified? %>
        <span class="relative z-20 inline-flex items-center flex-shrink-0 bg-blue-50 text-blue-600 rounded-full px-1.5 py-0.5 text-xs font-semibold gap-0.5" title="Verified Store">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Verified
        </span>
      <% end %>
    </div>

    <!-- City + category -->
    <div class="flex items-center gap-2 flex-wrap mb-2.5">
      <% if store.city.present? %>
        <span class="inline-flex items-center gap-1 text-xs text-slate-400 font-medium">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <%= store.city %>
        </span>
      <% end %>
      <span class="text-xs px-2 py-0.5 rounded-full font-semibold
        <%= store.grocery? ? 'bg-green-100 text-green-700' : store.pharmacy? ? 'bg-blue-100 text-blue-700' : 'bg-purple-100 text-purple-700' %>">
        <%= store.category.humanize %>
      </span>
    </div>

    <% if store.description.present? %>
      <p class="text-xs text-slate-400 line-clamp-2 leading-relaxed flex-1"><%= store.description %></p>
    <% end %>
  </div>
</div>
