<div class="bg-white rounded-xl shadow hover:shadow-md transition overflow-hidden">
  <%= link_to store_path(store) do %>
    <div class="h-32 bg-green-100 flex items-center justify-center">
      <% if store.logo.attached? %>
        <%= image_tag store.logo, class: "h-full w-full object-cover" %>
      <% else %>
        <span class="text-5xl">
          <%= store.grocery? ? "🥦" : store.pharmacy? ? "💊" : "👗" %>
        </span>
      <% end %>
    </div>
    <div class="p-4">
      <div class="flex items-start justify-between">
        <h3 class="font-semibold text-gray-800 text-sm"><%= store.name %></h3>
        <% if store.featured? %>
          <span class="text-yellow-500 text-xs">⭐</span>
        <% end %>
      </div>
      <p class="text-xs text-gray-500 mt-1"><%= store.city %></p>
      <span class="inline-block mt-2 px-2 py-0.5 text-xs rounded-full
        <%= store.grocery? ? 'bg-green-100 text-green-700' :
            store.pharmacy? ? 'bg-blue-100 text-blue-700' :
            'bg-purple-100 text-purple-700' %>">
        <%= store.category.humanize %>
      </span>
    </div>
  <% end %>
</div>
