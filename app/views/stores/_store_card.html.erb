<%= link_to store_path(store), class: "group bg-white rounded-2xl border border-slate-200 overflow-hidden hover:border-green-300 hover:shadow-lg hover:-translate-y-0.5 transition-all duration-200 flex flex-col" do %>
  <!-- Banner -->
  <div class="h-32 relative overflow-hidden bg-gradient-to-br
    <%= store.grocery? ? 'from-green-400 to-emerald-500' : store.pharmacy? ? 'from-blue-400 to-blue-600' : store.respond_to?(:electronics?) && store.electronics? ? 'from-amber-400 to-orange-500' : 'from-purple-400 to-pink-500' %>">
    <% if store.banner.attached? %>
      <%= image_tag store.banner, class: "w-full h-full object-cover absolute inset-0 group-hover:scale-105 transition-transform duration-700" %>
      <div class="absolute inset-0 bg-gradient-to-t from-black/30 via-transparent to-transparent"></div>
    <% else %>
      <div class="absolute inset-0 opacity-10" style="background-image: linear-gradient(rgba(255,255,255,0.2) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.2) 1px, transparent 1px); background-size: 20px 20px;"></div>
    <% end %>

    <% if store.featured? %>
      <span class="absolute top-2.5 right-2.5 bg-amber-400 text-amber-900 text-xs font-black px-2.5 py-0.5 rounded-full shadow-sm">⭐ Featured</span>
    <% end %>

    <!-- Logo -->
    <div class="absolute bottom-0 left-4 translate-y-1/2">
      <% if store.logo.attached? %>
        <%= image_tag store.logo, class: "w-11 h-11 rounded-xl border-2 border-white shadow-md object-cover" %>
      <% else %>
        <div class="w-11 h-11 bg-white rounded-xl border-2 border-white shadow-md flex items-center justify-center text-xl">
          <%= store.grocery? ? "🥦" : store.pharmacy? ? "💊" : "🛍️" %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Content -->
  <div class="pt-8 pb-4 px-4 flex-1 flex flex-col">
    <h3 class="font-bold text-slate-900 text-sm leading-snug group-hover:text-green-700 transition line-clamp-1 mb-1"><%= store.name %></h3>
    <div class="flex items-center gap-2 flex-wrap mb-2">
      <% if store.city.present? %>
        <span class="inline-flex items-center gap-1 text-xs text-slate-400 font-medium">
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <%= store.city %>
        </span>
      <% end %>
      <span class="text-xs px-2 py-0.5 rounded-full font-semibold
        <%= store.grocery? ? 'bg-green-100 text-green-700' : store.pharmacy? ? 'bg-blue-100 text-blue-700' : 'bg-purple-100 text-purple-700' %>">
        <%= store.category.humanize %>
      </span>
    </div>
    <% if store.description.present? %>
      <p class="text-xs text-slate-400 line-clamp-2 leading-relaxed flex-1"><%= store.description %></p>
    <% end %>
  </div>
<% end %>
