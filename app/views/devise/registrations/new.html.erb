<% content_for :title, "Create Account" %>

<div class="min-h-screen bg-gray-50 flex items-center justify-center py-12 px-4">
  <div class="max-w-md w-full bg-white rounded-xl shadow-md p-8">
    <div class="text-center mb-6">
      <span class="text-4xl">🛒</span>
      <h2 class="text-2xl font-bold mt-2">Join BazaarPK</h2>
      <% role = params[:role] || resource.role || "customer" %>
      <p class="text-gray-500 text-sm mt-1">
        <% if role == "vendor" %>
          Register your store and start selling
        <% else %>
          Shop from local Pakistani businesses
        <% end %>
      </p>
    </div>

    <!-- Role toggle -->
    <div class="flex rounded-lg overflow-hidden border mb-6">
      <%= link_to "Customer", new_user_registration_path(role: "customer"),
            class: "flex-1 text-center py-2 text-sm font-medium #{role == 'customer' ? 'bg-green-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-50'}" %>
      <%= link_to "Store Owner", new_user_registration_path(role: "vendor"),
            class: "flex-1 text-center py-2 text-sm font-medium #{role == 'vendor' ? 'bg-green-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-50'}" %>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <%= f.hidden_field :role, value: role %>

      <div class="space-y-4">
        <div>
          <%= f.label :name, "Full Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :name, autofocus: true,
                class: "w-full border rounded-lg px-3 py-2 text-sm focus:ring-green-500 focus:border-green-500" %>
        </div>

        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, autocomplete: "email",
                class: "w-full border rounded-lg px-3 py-2 text-sm focus:ring-green-500 focus:border-green-500" %>
        </div>

        <div>
          <%= f.label :phone, "Phone (Pakistani mobile)", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :phone, placeholder: "03001234567",
                class: "w-full border rounded-lg px-3 py-2 text-sm focus:ring-green-500 focus:border-green-500" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <% if @minimum_password_length %>
            <span class="text-xs text-gray-400">(<%= @minimum_password_length %> characters minimum)</span>
          <% end %>
          <%= f.password_field :password, autocomplete: "new-password",
                class: "w-full border rounded-lg px-3 py-2 text-sm focus:ring-green-500 focus:border-green-500" %>
        </div>

        <div>
          <%= f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password_confirmation, autocomplete: "new-password",
                class: "w-full border rounded-lg px-3 py-2 text-sm focus:ring-green-500 focus:border-green-500" %>
        </div>

        <%= f.submit role == "vendor" ? "Create Store Account" : "Create Account",
              class: "w-full bg-green-600 hover:bg-green-700 text-white font-bold py-3 rounded-lg cursor-pointer mt-2" %>
      </div>
    <% end %>

    <div class="text-center mt-4 text-sm text-gray-500">
      Already have an account? <%= link_to "Sign in", new_user_session_path, class: "text-green-600 hover:underline" %>
    </div>
  </div>
</div>
