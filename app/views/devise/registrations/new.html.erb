<% content_for :title, "Create Account" %>
<% role = params[:role] || resource.role || "customer" %>

<div class="min-h-screen flex">

  <!-- ── Left panel ── -->
  <div class="hidden lg:flex lg:w-[42%] flex-col justify-between p-12 relative overflow-hidden" style="background: linear-gradient(145deg, #0a0f1e 0%, #0d2010 55%, #0a0f1e 100%);">
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute top-1/3 right-0 w-80 h-80 rounded-full" style="background: radial-gradient(circle, rgba(34,197,94,0.10) 0%, transparent 65%);"></div>
      <div class="absolute bottom-1/4 -left-10 w-60 h-60 rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.07) 0%, transparent 65%);"></div>
    </div>

    <div class="relative">
      <a href="<%= root_path %>" class="inline-flex items-center gap-3">
        <div class="w-9 h-9 rounded-xl flex items-center justify-center shadow-lg" style="background: linear-gradient(135deg, #22c55e 0%, #15803d 100%);">
          <span class="text-white font-black text-base leading-none">B</span>
        </div>
        <span class="text-white font-bold text-lg tracking-tight">BazaarPK</span>
      </a>
    </div>

    <div class="relative">
      <% if role == "vendor" %>
        <div class="inline-flex items-center gap-2 mb-6 bg-white/6 border border-white/10 rounded-full px-4 py-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-green-400 flex-shrink-0"></span>
          <span class="text-green-300 text-xs font-medium">For Business Owners</span>
        </div>
        <h2 class="text-4xl font-bold text-white leading-tight mb-4 tracking-tight">
          Your store,<br>your rules.
        </h2>
        <p class="text-slate-400 text-sm leading-relaxed mb-8">
          List your products, manage orders, track revenue, and run a POS terminal — all from one dashboard.
        </p>
        <ul class="space-y-3.5">
          <% [
            "Free to start — list up to 20 products",
            "Vendor dashboard with analytics",
            "Integrated POS terminal for walk-ins",
            "JazzCash / Easypaisa payments (coming soon)",
          ].each do |text| %>
            <li class="flex items-center gap-3">
              <div class="w-5 h-5 bg-green-500/15 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-3 h-3 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-slate-400 text-sm"><%= text %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="inline-flex items-center gap-2 mb-6 bg-white/6 border border-white/10 rounded-full px-4 py-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-green-400 flex-shrink-0"></span>
          <span class="text-green-300 text-xs font-medium">Shop Local, Support Pakistan</span>
        </div>
        <h2 class="text-4xl font-bold text-white leading-tight mb-4 tracking-tight">
          Your neighborhood<br>at your fingertips.
        </h2>
        <p class="text-slate-400 text-sm leading-relaxed mb-8">
          Order groceries, medicines, and clothing from local stores you trust. Fast delivery, cash on delivery.
        </p>
        <ul class="space-y-3.5">
          <% [
            "Thousands of local stores nationwide",
            "Cash on delivery, no card needed",
            "Track your orders in real time",
            "Free delivery on your first order",
          ].each do |text| %>
            <li class="flex items-center gap-3">
              <div class="w-5 h-5 bg-green-500/15 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-3 h-3 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-slate-400 text-sm"><%= text %></span>
            </li>
          <% end %>
        </ul>
      <% end %>
    </div>

    <div class="relative text-xs text-slate-700">
      &copy; <%= Date.today.year %> BazaarPK &middot; Supporting local businesses
    </div>
  </div>

  <!-- ── Right panel ── -->
  <div class="flex-1 flex items-center justify-center bg-white px-6 py-10 overflow-y-auto">
    <div class="w-full max-w-sm py-4">

      <div class="flex items-center justify-center gap-2.5 mb-8 lg:hidden">
        <div class="w-9 h-9 rounded-xl flex items-center justify-center shadow-md" style="background: linear-gradient(135deg, #22c55e 0%, #15803d 100%);">
          <span class="text-white font-black text-base leading-none">B</span>
        </div>
        <span class="text-xl font-bold text-slate-900 tracking-tight">BazaarPK</span>
      </div>

      <div class="mb-6">
        <h1 class="text-2xl font-bold text-slate-900 tracking-tight">
          <%= role == "vendor" ? "Register your store" : "Create your account" %>
        </h1>
        <p class="text-slate-500 mt-1.5 text-sm">
          <%= role == "vendor" ? "Start selling online in minutes" : "Shop from local Pakistani businesses" %>
        </p>
      </div>

      <!-- Role toggle -->
      <div class="flex bg-slate-100 rounded-xl p-1 mb-6">
        <%= link_to "Customer", new_user_registration_path(role: "customer"),
              class: "flex-1 text-center py-2.5 text-sm font-semibold rounded-xl transition-all duration-150 #{role == 'customer' ? 'bg-white text-slate-900 shadow-sm' : 'text-slate-500 hover:text-slate-700'}" %>
        <%= link_to "Store Owner", new_user_registration_path(role: "vendor"),
              class: "flex-1 text-center py-2.5 text-sm font-semibold rounded-xl transition-all duration-150 #{role == 'vendor' ? 'bg-white text-slate-900 shadow-sm' : 'text-slate-500 hover:text-slate-700'}" %>
      </div>

      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <%= f.hidden_field :role, value: role %>
        <div class="space-y-4">

          <div>
            <%= f.label :name, "Full Name" %>
            <%= f.text_field :name, autofocus: true, placeholder: "Hamza Khan" %>
          </div>

          <div>
            <%= f.label :email, "Email Address" %>
            <%= f.email_field :email, autocomplete: "email", placeholder: "you@example.com" %>
          </div>

          <div>
            <%= f.label :phone, "Mobile Number" %>
            <%= f.text_field :phone, placeholder: "0300 1234567" %>
          </div>

          <div class="grid grid-cols-2 gap-3">
            <div>
              <%= f.label :password do %>
                Password
                <% if @minimum_password_length %>
                  <span class="font-normal text-slate-400">(min <%= @minimum_password_length %>)</span>
                <% end %>
              <% end %>
              <%= f.password_field :password, autocomplete: "new-password", placeholder: "••••••••" %>
            </div>
            <div>
              <%= f.label :password_confirmation, "Confirm" %>
              <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "••••••••" %>
            </div>
          </div>

          <%= f.submit role == "vendor" ? "Create Store Account" : "Create Account",
                class: "w-full py-3 bg-green-600 hover:bg-green-700 active:bg-green-800 active:scale-[0.99] text-white font-semibold rounded-xl cursor-pointer transition-all duration-150 text-sm mt-1" %>
        </div>
      <% end %>

      <p class="text-center mt-5 text-sm text-slate-500">
        Already have an account?
        <%= link_to "Sign in", new_user_session_path, class: "text-green-600 hover:text-green-700 font-semibold transition-colors" %>
      </p>

    </div>
  </div>

</div>
