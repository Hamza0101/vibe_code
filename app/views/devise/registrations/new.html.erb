<% content_for :title, "Create Account" %>
<% role = params[:role] || resource.role || "customer" %>

<div class="min-h-screen flex">

  <!-- Left branding panel -->
  <div class="hidden lg:flex lg:w-[40%] bg-gradient-to-br from-slate-900 via-green-950 to-slate-900 relative overflow-hidden flex-col justify-between p-12">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-20 right-10 w-80 h-80 bg-green-500/10 rounded-full blur-3xl"></div>
      <div class="absolute bottom-10 left-5 w-64 h-64 bg-emerald-400/8 rounded-full blur-3xl"></div>
    </div>

    <div class="relative">
      <a href="<%= root_path %>" class="flex items-center gap-3">
        <div class="w-10 h-10 bg-green-500 rounded-xl flex items-center justify-center shadow-lg shadow-green-500/30">
          <span class="text-white font-black text-lg">B</span>
        </div>
        <span class="text-xl font-bold text-white tracking-tight">BazaarPK</span>
      </a>
    </div>

    <div class="relative">
      <% if role == "vendor" %>
        <div class="inline-flex items-center gap-2 bg-green-500/15 border border-green-500/20 rounded-full px-4 py-1.5 mb-6">
          <span class="text-green-400 text-xs font-bold uppercase tracking-widest">For Business Owners</span>
        </div>
        <h2 class="text-4xl font-bold text-white leading-tight mb-4">
          Your store,<br>your rules.
        </h2>
        <p class="text-slate-400 text-base leading-relaxed mb-8">
          List your products, manage orders, track revenue, and even run a POS terminal — all from one dashboard.
        </p>
        <ul class="space-y-4">
          <% [
            ["Free to start — list up to 20 products", "M5 13l4 4L19 7"],
            ["Vendor dashboard with analytics", "M5 13l4 4L19 7"],
            ["Integrated POS terminal for walk-ins", "M5 13l4 4L19 7"],
            ["JazzCash / Easypaisa payments (coming soon)", "M5 13l4 4L19 7"],
          ].each do |text, icon| %>
            <li class="flex items-center gap-3">
              <div class="w-5 h-5 bg-green-500/20 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-3 h-3 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="<%= icon %>"/>
                </svg>
              </div>
              <span class="text-slate-300 text-sm"><%= text %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <div class="inline-flex items-center gap-2 bg-green-500/15 border border-green-500/20 rounded-full px-4 py-1.5 mb-6">
          <span class="text-green-400 text-xs font-bold uppercase tracking-widest">Shop Local, Support Pakistan</span>
        </div>
        <h2 class="text-4xl font-bold text-white leading-tight mb-4">
          Your neighborhood<br>at your fingertips.
        </h2>
        <p class="text-slate-400 text-base leading-relaxed mb-8">
          Order groceries, medicines, and clothing from local stores you trust. Fast delivery, cash on delivery.
        </p>
        <ul class="space-y-4">
          <% [
            ["Thousands of local stores nationwide", "M5 13l4 4L19 7"],
            ["Cash on delivery, no card needed", "M5 13l4 4L19 7"],
            ["Track your orders in real time", "M5 13l4 4L19 7"],
            ["Free delivery on your first order", "M5 13l4 4L19 7"],
          ].each do |text, icon| %>
            <li class="flex items-center gap-3">
              <div class="w-5 h-5 bg-green-500/20 rounded-full flex items-center justify-center flex-shrink-0">
                <svg class="w-3 h-3 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="<%= icon %>"/>
                </svg>
              </div>
              <span class="text-slate-300 text-sm"><%= text %></span>
            </li>
          <% end %>
        </ul>
      <% end %>
    </div>

    <div class="relative text-xs text-slate-600">
      &copy; <%= Date.today.year %> BazaarPK · Made with ❤️ in Pakistan
    </div>
  </div>

  <!-- Right form panel -->
  <div class="flex-1 flex items-center justify-center bg-slate-50 px-6 py-10 overflow-y-auto">
    <div class="w-full max-w-md">

      <!-- Mobile logo -->
      <div class="flex items-center justify-center gap-2 mb-6 lg:hidden">
        <div class="w-9 h-9 bg-green-600 rounded-xl flex items-center justify-center shadow-md">
          <span class="text-white font-black text-base">B</span>
        </div>
        <span class="text-xl font-bold text-slate-900">BazaarPK</span>
      </div>

      <div class="text-center mb-6">
        <h1 class="text-2xl font-bold text-slate-900 tracking-tight">
          <%= role == "vendor" ? "Register your store" : "Create your account" %>
        </h1>
        <p class="text-slate-500 mt-1.5 text-sm">
          <%= role == "vendor" ? "Start selling online in minutes" : "Shop from local Pakistani businesses" %>
        </p>
      </div>

      <!-- Role toggle -->
      <div class="flex bg-slate-100 rounded-xl p-1 mb-6">
        <%= link_to "Customer", new_user_registration_path(role: "customer"),
              class: "flex-1 text-center py-2.5 text-sm font-semibold rounded-lg transition duration-150 #{role == 'customer' ? 'bg-white text-slate-900 shadow-sm' : 'text-slate-500 hover:text-slate-700'}" %>
        <%= link_to "Store Owner", new_user_registration_path(role: "vendor"),
              class: "flex-1 text-center py-2.5 text-sm font-semibold rounded-lg transition duration-150 #{role == 'vendor' ? 'bg-white text-slate-900 shadow-sm' : 'text-slate-500 hover:text-slate-700'}" %>
      </div>

      <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-8">
        <%= render "devise/shared/error_messages", resource: resource %>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
          <%= f.hidden_field :role, value: role %>

          <div class="space-y-5">
            <div>
              <%= f.label :name, "Full Name" %>
              <%= f.text_field :name, autofocus: true,
                    placeholder: "Hamza Khan" %>
            </div>

            <div>
              <%= f.label :email %>
              <%= f.email_field :email, autocomplete: "email",
                    placeholder: "you@example.com" %>
            </div>

            <div>
              <%= f.label :phone, "Pakistani Mobile Number" %>
              <%= f.text_field :phone, placeholder: "03001234567" %>
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <%= f.label :password %>
                <% if @minimum_password_length %>
                  <span class="text-xs text-slate-400 ml-1">(min <%= @minimum_password_length %> chars)</span>
                <% end %>
                <%= f.password_field :password, autocomplete: "new-password",
                      placeholder: "••••••••" %>
              </div>
              <div>
                <%= f.label :password_confirmation, "Confirm Password" %>
                <%= f.password_field :password_confirmation, autocomplete: "new-password",
                      placeholder: "••••••••" %>
              </div>
            </div>

            <%= f.submit role == "vendor" ? "Create Store Account" : "Create Account",
                  class: "w-full py-3 bg-green-600 hover:bg-green-700 active:bg-green-800 text-white font-semibold rounded-xl shadow-sm cursor-pointer transition duration-150 text-sm mt-2" %>
          </div>
        <% end %>
      </div>

      <p class="text-center mt-5 text-sm text-slate-500">
        Already have an account?
        <%= link_to "Sign in", new_user_session_path,
              class: "text-green-600 hover:text-green-700 font-semibold" %>
      </p>
    </div>
  </div>
</div>
