<% content_for :title, "Sign In" %>

<div class="min-h-screen flex">

  <!-- ── Left panel ── -->
  <div class="hidden lg:flex lg:w-[44%] flex-col justify-between p-12 relative overflow-hidden" style="background: linear-gradient(145deg, #0a0f1e 0%, #0d2010 55%, #0a0f1e 100%);">
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute top-1/4 -left-20 w-80 h-80 rounded-full" style="background: radial-gradient(circle, rgba(34,197,94,0.12) 0%, transparent 65%);"></div>
      <div class="absolute bottom-1/4 right-0 w-64 h-64 rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.08) 0%, transparent 65%);"></div>
    </div>

    <div class="relative">
      <a href="<%= root_path %>" class="inline-flex items-center gap-3">
        <div class="w-9 h-9 rounded-xl flex items-center justify-center shadow-lg" style="background: linear-gradient(135deg, #22c55e 0%, #15803d 100%);">
          <span class="text-white font-black text-base leading-none">B</span>
        </div>
        <span class="text-white font-bold text-lg tracking-tight">BazaarPK</span>
      </a>
    </div>

    <div class="relative">
      <div class="inline-flex items-center gap-2 mb-7 bg-white/6 border border-white/10 rounded-full px-4 py-1.5">
        <span class="w-1.5 h-1.5 rounded-full bg-green-400 flex-shrink-0"></span>
        <span class="text-green-300 text-xs font-medium tracking-wide">Pakistan's Local Marketplace</span>
      </div>
      <h2 class="text-4xl font-bold text-white leading-tight mb-4 tracking-tight">
        Grow your business<br>with BazaarPK
      </h2>
      <p class="text-slate-400 text-base leading-relaxed mb-10">
        Thousands of businesses across Pakistan trust BazaarPK to reach more customers and grow their revenue.
      </p>
      <div class="grid grid-cols-2 gap-3">
        <% [["5,000+", "Active stores"], ["50K+", "Products listed"], ["200K+", "Customers"], ["10+", "Cities"]].each do |num, label| %>
          <div class="bg-white/5 border border-white/8 rounded-xl p-4">
            <p class="text-2xl font-bold text-white leading-none mb-1"><%= num %></p>
            <p class="text-slate-500 text-xs"><%= label %></p>
          </div>
        <% end %>
      </div>
    </div>

    <div class="relative text-xs text-slate-700">
      &copy; <%= Date.today.year %> BazaarPK &middot; Supporting local businesses
    </div>
  </div>

  <!-- ── Right panel ── -->
  <div class="flex-1 flex items-center justify-center bg-white px-6 py-12">
    <div class="w-full max-w-sm">

      <div class="flex items-center justify-center gap-2.5 mb-10 lg:hidden">
        <div class="w-9 h-9 rounded-xl flex items-center justify-center shadow-md" style="background: linear-gradient(135deg, #22c55e 0%, #15803d 100%);">
          <span class="text-white font-black text-base leading-none">B</span>
        </div>
        <span class="text-xl font-bold text-slate-900 tracking-tight">BazaarPK</span>
      </div>

      <div class="mb-8">
        <h1 class="text-2xl font-bold text-slate-900 tracking-tight">Welcome back</h1>
        <p class="text-slate-500 mt-1.5 text-sm">Sign in to your account to continue</p>
      </div>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-4">
          <div>
            <%= f.label :email, "Email address" %>
            <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com" %>
          </div>

          <div>
            <div class="flex items-center justify-between mb-1.5">
              <label class="text-sm font-medium text-slate-700" style="margin-bottom: 0;">Password</label>
              <%= link_to "Forgot?", new_user_password_path, class: "text-xs text-green-600 hover:text-green-700 font-medium transition-colors" %>
            </div>
            <%= f.password_field :password, autocomplete: "current-password", placeholder: "••••••••" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <label class="flex items-center gap-2.5 cursor-pointer" style="margin-bottom: 0;">
              <%= f.check_box :remember_me, class: "w-4 h-4 rounded border-slate-300 cursor-pointer accent-green-600" %>
              <span class="text-sm text-slate-600 font-normal">Keep me signed in</span>
            </label>
          <% end %>

          <%= f.submit "Sign in",
                class: "w-full py-3 bg-green-600 hover:bg-green-700 active:bg-green-800 active:scale-[0.99] text-white font-semibold rounded-xl cursor-pointer transition-all duration-150 text-sm mt-1" %>
        </div>
      <% end %>

      <div class="my-7 flex items-center gap-3">
        <div class="flex-1 h-px bg-slate-100"></div>
        <span class="text-xs text-slate-400 font-medium">New to BazaarPK?</span>
        <div class="flex-1 h-px bg-slate-100"></div>
      </div>

      <div class="grid grid-cols-2 gap-3">
        <%= link_to new_user_registration_path, class: "flex items-center justify-center gap-1.5 px-4 py-2.5 bg-slate-50 hover:bg-slate-100 border border-slate-200 rounded-xl text-sm font-medium text-slate-700 transition-all duration-150" do %>
          <svg class="w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          Customer
        <% end %>
        <%= link_to new_user_registration_path(role: "vendor"), class: "flex items-center justify-center gap-1.5 px-4 py-2.5 bg-green-50 hover:bg-green-100 border border-green-200 rounded-xl text-sm font-medium text-green-700 transition-all duration-150" do %>
          <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          List a store
        <% end %>
      </div>

      <% if Rails.env.development? %>
        <div class="mt-8 bg-slate-50 border border-slate-200 rounded-xl p-4 text-xs">
          <p class="font-semibold text-slate-600 mb-2.5 uppercase tracking-wide text-[10px]">Dev Accounts</p>
          <div class="space-y-1.5 text-[11px] font-mono text-slate-500">
            <div class="flex justify-between"><span class="text-slate-400">admin</span><span>admin@bazaarpk.com / admin123456</span></div>
            <div class="flex justify-between"><span class="text-slate-400">vendor</span><span>vendor@test.com / password123</span></div>
            <div class="flex justify-between"><span class="text-slate-400">customer</span><span>customer@test.com / password123</span></div>
          </div>
        </div>
      <% end %>

    </div>
  </div>

</div>
