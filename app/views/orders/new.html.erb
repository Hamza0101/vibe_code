<% content_for :title, "Checkout" %>

<div class="max-w-5xl mx-auto px-4 py-10">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-slate-900">Checkout</h1>
    <p class="text-slate-500 text-sm mt-1">Review your order and confirm delivery details</p>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Left: Form -->
    <div class="lg:col-span-2 space-y-5">
      <%= form_with url: orders_path, method: :post do |f| %>

        <!-- Delivery Address -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
          <div class="flex items-center justify-between mb-5">
            <h2 class="font-bold text-slate-900 flex items-center gap-2">
              <span class="w-6 h-6 bg-green-100 text-green-700 rounded-lg flex items-center justify-center text-xs font-bold">1</span>
              Delivery Address
            </h2>
            <%= link_to "+ Add new address", new_address_path, class: "text-sm text-green-700 hover:text-green-800 font-semibold" %>
          </div>

          <% if @addresses.any? %>
            <div class="space-y-3">
              <% @addresses.each do |address| %>
                <label class="flex items-start gap-3 p-4 border border-slate-200 rounded-xl cursor-pointer hover:border-green-400 hover:bg-green-50/50 transition has-[:checked]:border-green-500 has-[:checked]:bg-green-50">
                  <%= radio_button_tag "order[address_id]", address.id, address.is_default?, class: "mt-0.5 accent-green-600" %>
                  <div class="text-sm">
                    <p class="font-semibold text-slate-800"><%= address.city %>, <%= address.province %></p>
                    <p class="text-slate-500 mt-0.5"><%= address.line1 %><%= address.line2.present? ? ", #{address.line2}" : "" %></p>
                    <% if address.is_default? %>
                      <span class="text-xs text-green-600 font-semibold mt-1 block">Default address</span>
                    <% end %>
                  </div>
                </label>
              <% end %>
            </div>
          <% else %>
            <div class="text-center py-8 border-2 border-dashed border-slate-200 rounded-xl">
              <p class="text-slate-500 text-sm mb-3">No saved addresses yet</p>
              <%= link_to "Add a delivery address", new_address_path,
                    class: "bg-green-600 hover:bg-green-700 text-white px-5 py-2.5 rounded-xl text-sm font-semibold transition" %>
            </div>
          <% end %>
        </div>

        <!-- Payment Method -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
          <h2 class="font-bold text-slate-900 flex items-center gap-2 mb-5">
            <span class="w-6 h-6 bg-green-100 text-green-700 rounded-lg flex items-center justify-center text-xs font-bold">2</span>
            Payment Method
          </h2>

          <div class="space-y-3">
            <label class="flex items-center gap-3 p-4 border border-slate-200 rounded-xl cursor-pointer hover:border-green-400 transition has-[:checked]:border-green-500 has-[:checked]:bg-green-50">
              <%= radio_button_tag "order[payment_method]", "cash_on_delivery", true, class: "accent-green-600" %>
              <div>
                <p class="text-sm font-semibold text-slate-800">Cash on Delivery (COD)</p>
                <p class="text-xs text-slate-400">Pay when your order arrives</p>
              </div>
            </label>
            <label class="flex items-center gap-3 p-4 border border-slate-200 rounded-xl cursor-pointer hover:border-green-400 transition has-[:checked]:border-green-500 has-[:checked]:bg-green-50">
              <%= radio_button_tag "order[payment_method]", "jazzcash", false, class: "accent-green-600" %>
              <div>
                <p class="text-sm font-semibold text-slate-800">JazzCash</p>
                <p class="text-xs text-slate-400">Pay via JazzCash mobile wallet</p>
              </div>
            </label>
            <label class="flex items-center gap-3 p-4 border border-slate-200 rounded-xl cursor-pointer hover:border-green-400 transition has-[:checked]:border-green-500 has-[:checked]:bg-green-50">
              <%= radio_button_tag "order[payment_method]", "easypaisa", false, class: "accent-green-600" %>
              <div>
                <p class="text-sm font-semibold text-slate-800">EasyPaisa</p>
                <p class="text-xs text-slate-400">Pay via EasyPaisa mobile wallet</p>
              </div>
            </label>
          </div>
        </div>

        <!-- Notes -->
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6">
          <h2 class="font-bold text-slate-900 flex items-center gap-2 mb-4">
            <span class="w-6 h-6 bg-green-100 text-green-700 rounded-lg flex items-center justify-center text-xs font-bold">3</span>
            Order Notes <span class="text-slate-400 font-normal text-sm">(optional)</span>
          </h2>
          <%= text_area_tag "order[notes]", "",
                placeholder: "Any special delivery instructions or notes...",
                class: "w-full border border-slate-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green-500 resize-none",
                rows: 3 %>
        </div>

        <% if @addresses.any? %>
          <%= f.submit "Place Order",
                class: "w-full bg-green-600 hover:bg-green-700 text-white font-bold py-4 rounded-2xl text-lg cursor-pointer transition shadow-md" %>
        <% end %>
      <% end %>
    </div>

    <!-- Right: Order Summary -->
    <div class="lg:col-span-1">
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 sticky top-20">
        <h2 class="font-bold text-slate-900 text-base mb-5">Order Summary</h2>

        <div class="space-y-2 mb-5">
          <% @cart.cart_items.includes(:product, :product_variant).each do |item| %>
            <div class="flex justify-between text-sm">
              <span class="text-slate-600 flex-1 min-w-0 pr-2 truncate">
                <%= item.product.name %>
                <% if item.product_variant %><span class="text-slate-400"> (<%= item.product_variant.value %>)</span><% end %>
                <span class="text-slate-400"> ×<%= item.quantity %></span>
              </span>
              <span class="font-medium text-slate-800 flex-shrink-0">Rs. <%= number_with_delimiter(item.subtotal) %></span>
            </div>
          <% end %>
        </div>

        <div class="border-t border-slate-100 pt-4 space-y-2">
          <div class="flex justify-between text-sm text-slate-500">
            <span>Subtotal</span>
            <span class="text-slate-700 font-medium">Rs. <%= number_with_delimiter(@cart.total) %></span>
          </div>
          <div class="flex justify-between text-sm text-slate-500">
            <span>Delivery</span>
            <span class="text-slate-700 font-medium">Rs. 100</span>
          </div>
          <div class="flex justify-between font-bold text-base pt-2 border-t border-slate-100">
            <span class="text-slate-900">Total</span>
            <span class="text-green-700">Rs. <%= number_with_delimiter(@cart.total + 100) %></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
