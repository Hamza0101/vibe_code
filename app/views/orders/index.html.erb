<% content_for :title, "My Orders" %>

<div class="max-w-3xl mx-auto px-4 py-8">
  <h1 class="text-2xl font-bold mb-6">My Orders</h1>

  <% if @orders.any? %>
    <div class="space-y-4">
      <% @orders.each do |order| %>
        <div class="bg-white rounded-xl shadow p-4 flex items-center justify-between">
          <div>
            <p class="font-semibold"><%= order.order_number %></p>
            <p class="text-sm text-gray-500"><%= order.store.name %> · <%= order.created_at.strftime("%b %d, %Y") %></p>
          </div>
          <div class="text-right">
            <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold
              <%= order.pending? ? 'bg-yellow-100 text-yellow-700' :
                  order.delivered? ? 'bg-green-100 text-green-700' :
                  order.cancelled? ? 'bg-red-100 text-red-700' :
                  'bg-blue-100 text-blue-700' %>">
              <%= order.status.humanize %>
            </span>
            <p class="font-bold text-green-700 mt-1">Rs. <%= number_with_delimiter(order.total) %></p>
            <%= link_to "View →", order_path(order), class: "text-green-600 text-sm hover:underline" %>
          </div>
        </div>
      <% end %>
    </div>
    <div class="mt-6"><%== pagy_nav(@pagy) %></div>
  <% else %>
    <div class="text-center py-16 text-gray-500">
      <p class="text-5xl mb-4">📭</p>
      <p>No orders yet. Start shopping!</p>
      <%= link_to "Browse Stores", stores_path, class: "mt-4 inline-block bg-green-600 text-white px-6 py-2 rounded-lg" %>
    </div>
  <% end %>
</div>
