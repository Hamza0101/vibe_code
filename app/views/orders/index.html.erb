<% content_for :title, "My Orders" %>

<div class="max-w-4xl mx-auto px-4 py-10">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-slate-900">My Orders</h1>
    <p class="text-slate-500 text-sm mt-1">Track and manage your orders</p>
  </div>

  <% if @orders.any? %>
    <div class="space-y-4">
      <% @orders.each do |order| %>
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm hover:shadow-md transition p-5">
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div class="flex items-start gap-4">
              <div class="w-12 h-12 bg-green-50 rounded-xl flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                </svg>
              </div>
              <div>
                <p class="font-bold text-slate-900">#<%= order.order_number %></p>
                <p class="text-sm text-slate-500 mt-0.5">
                  <%= link_to order.store.name, store_path(order.store), class: "text-green-700 hover:text-green-800 font-medium" %>
                  · <%= order.created_at.strftime("%b %d, %Y") %>
                </p>
                <p class="text-xs text-slate-400 mt-0.5">
                  <%= pluralize(order.order_items.count, "item") %>
                </p>
              </div>
            </div>

            <div class="flex items-center justify-between sm:justify-end sm:flex-col sm:items-end gap-3">
              <div class="text-right">
                <span class="inline-flex px-3 py-1 rounded-full text-xs font-bold
                  <%= order.pending? ? 'bg-amber-100 text-amber-700' :
                      order.delivered? ? 'bg-green-100 text-green-700' :
                      order.cancelled? ? 'bg-red-100 text-red-700' :
                      order.confirmed? ? 'bg-blue-100 text-blue-700' : 'bg-slate-100 text-slate-600' %>">
                  <%= order.status.humanize %>
                </span>
                <p class="font-bold text-slate-900 mt-1.5">Rs. <%= number_with_delimiter(order.total) %></p>
              </div>
              <%= link_to "View Details", order_path(order),
                    class: "text-sm text-green-700 hover:text-green-800 font-semibold hover:underline" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
    <div class="mt-8 flex justify-center"><%== pagy_nav(@pagy) %></div>
  <% else %>
    <div class="text-center py-24 bg-white rounded-2xl border border-slate-200">
      <div class="w-20 h-20 bg-slate-100 rounded-2xl flex items-center justify-center mx-auto mb-5">
        <svg class="w-10 h-10 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
        </svg>
      </div>
      <h3 class="text-xl font-semibold text-slate-700 mb-2">No orders yet</h3>
      <p class="text-slate-400 mb-6">Browse local stores and place your first order</p>
      <%= link_to "Start Shopping", stores_path,
            class: "bg-green-600 hover:bg-green-700 text-white font-semibold px-8 py-3 rounded-xl transition shadow-sm" %>
    </div>
  <% end %>
</div>
