<footer class="bg-slate-950 text-slate-400 mt-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-14 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-5 gap-10 mb-12">
      <!-- Brand (2 cols) -->
      <div class="md:col-span-2 space-y-4">
        <div class="flex items-center gap-2.5">
          <div class="w-8 h-8 rounded-xl flex items-center justify-center shadow-sm flex-shrink-0" style="background: linear-gradient(135deg, #22c55e 0%, #15803d 100%);">
            <span class="text-white font-black text-sm leading-none">B</span>
          </div>
          <span class="text-[15px] font-bold text-white tracking-tight">BazaarPK</span>
        </div>
        <p class="text-sm text-slate-500 leading-relaxed max-w-xs">
          Pakistan's trusted marketplace connecting local businesses with customers nationwide.
        </p>
      </div>

      <!-- Marketplace -->
      <div class="space-y-4">
        <h4 class="text-white text-xs font-semibold uppercase tracking-wider">Marketplace</h4>
        <ul class="space-y-2.5 text-sm">
          <li><%= link_to "Browse Stores", stores_path, class: "text-slate-500 hover:text-slate-200 transition-colors duration-150" %></li>
          <li><%= link_to "Grocery", stores_path(category: "grocery"), class: "text-slate-500 hover:text-slate-200 transition-colors duration-150" %></li>
          <li><%= link_to "Pharmacy", stores_path(category: "pharmacy"), class: "text-slate-500 hover:text-slate-200 transition-colors duration-150" %></li>
          <li><%= link_to "Clothing", stores_path(category: "clothing"), class: "text-slate-500 hover:text-slate-200 transition-colors duration-150" %></li>
          <li><%= link_to "Electronics", stores_path(category: "electronics"), class: "text-slate-500 hover:text-slate-200 transition-colors duration-150" %></li>
        </ul>
      </div>

      <!-- Vendors -->
      <div class="space-y-4">
        <h4 class="text-white text-xs font-semibold uppercase tracking-wider">Sell on BazaarPK</h4>
        <ul class="space-y-2.5 text-sm">
          <li><%= link_to "Register Store", new_user_registration_path(role: "vendor"), class: "text-slate-500 hover:text-slate-200 transition-colors duration-150" %></li>
          <li><%= link_to "Pricing Plans", subscriptions_path, class: "text-slate-500 hover:text-slate-200 transition-colors duration-150" %></li>
          <% if user_signed_in? && current_user.vendor? %>
            <li><%= link_to "My Dashboard", vendor_root_path, class: "text-slate-500 hover:text-slate-200 transition-colors duration-150" %></li>
          <% end %>
        </ul>
      </div>
    </div>

    <!-- Account links row + bottom bar -->
    <div class="border-t border-slate-800/60 mt-0 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-slate-600">&copy; <%= Date.today.year %> BazaarPK &middot; Supporting local businesses across Pakistan</p>
      <div class="flex items-center gap-4 text-xs text-slate-600">
        <% if user_signed_in? %>
          <%= link_to "My Orders", orders_path, class: "hover:text-slate-400 transition-colors duration-150" %>
          <%= link_to "Account", edit_user_registration_path, class: "hover:text-slate-400 transition-colors duration-150" %>
        <% else %>
          <%= link_to "Sign In", new_user_session_path, class: "hover:text-slate-400 transition-colors duration-150" %>
          <%= link_to "Create Account", new_user_registration_path, class: "hover:text-slate-400 transition-colors duration-150" %>
        <% end %>
      </div>
    </div>
  </div>
</footer>
