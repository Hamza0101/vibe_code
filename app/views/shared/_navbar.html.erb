<nav class="bg-white border-b border-slate-200 sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo + Search -->
      <div class="flex items-center gap-5 flex-1 min-w-0">
        <%= link_to root_path, class: "flex items-center gap-2.5 flex-shrink-0" do %>
          <div class="w-8 h-8 rounded-xl flex items-center justify-center shadow-sm flex-shrink-0" style="background: linear-gradient(135deg, #22c55e 0%, #15803d 100%);">
            <span class="text-white font-black text-sm leading-none">B</span>
          </div>
          <span class="text-[15px] font-bold text-slate-900 tracking-tight">BazaarPK</span>
        <% end %>

        <%= form_with url: root_path, method: :get, class: "hidden md:flex items-center ml-2 flex-1 max-w-sm" do |f| %>
          <div class="relative w-full">
            <svg class="absolute left-3.5 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/>
            </svg>
            <%= f.text_field :q, placeholder: "Search stores, products...",
                  class: "w-full pl-10 pr-4 py-2 bg-slate-100 border border-transparent rounded-xl text-sm focus:outline-none focus:bg-white focus:border-green-400 focus:ring-1 focus:ring-green-400 transition-all duration-150 font-medium text-slate-700 placeholder-slate-400",
                  value: params[:q], autocomplete: "off" %>
          </div>
        <% end %>
      </div>

      <!-- Nav links -->
      <div class="flex items-center gap-1 ml-3">
        <%= link_to stores_path, class: "hidden sm:flex items-center gap-1.5 px-3 py-2 rounded-xl text-sm font-semibold text-slate-600 hover:text-slate-900 hover:bg-slate-100 transition duration-150" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
          Stores
        <% end %>

        <!-- Cart -->
        <%= link_to cart_path, class: "relative flex items-center justify-center w-10 h-10 rounded-xl text-slate-600 hover:text-slate-900 hover:bg-slate-100 transition duration-150" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
          <% count = current_cart.item_count %>
          <% if count > 0 %>
            <span id="cart-count" class="absolute -top-0.5 -right-0.5 bg-green-600 text-white text-xs rounded-full w-4 h-4 flex items-center justify-center font-black leading-none shadow-sm">
              <%= count %>
            </span>
          <% else %>
            <span id="cart-count" class="hidden absolute -top-0.5 -right-0.5 bg-green-600 text-white text-xs rounded-full w-4 h-4 flex items-center justify-center font-black leading-none shadow-sm">0</span>
          <% end %>
        <% end %>

        <% if user_signed_in? %>
          <% if current_user.vendor? %>
            <%= link_to vendor_root_path, class: "hidden sm:flex items-center gap-1.5 px-3 py-2 rounded-xl text-sm font-semibold text-slate-600 hover:text-slate-900 hover:bg-slate-100 transition duration-150" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
              Dashboard
            <% end %>
          <% elsif current_user.admin? %>
            <%= link_to admin_root_path, class: "hidden sm:flex items-center gap-1.5 px-3 py-2 rounded-xl text-sm font-semibold text-slate-600 hover:text-slate-900 hover:bg-slate-100 transition duration-150" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
              Admin
            <% end %>
          <% end %>

          <!-- User avatar dropdown-like -->
          <div class="flex items-center gap-1 pl-1 ml-1 border-l border-slate-200">
            <div class="w-8 h-8 rounded-xl flex items-center justify-center text-xs font-bold text-white flex-shrink-0 shadow-sm" style="background: linear-gradient(135deg, #16a34a 0%, #15803d 100%);">
              <%= current_user.name&.first&.upcase || current_user.email.first.upcase %>
            </div>
            <%= button_to destroy_user_session_path, method: :delete,
                  class: "hidden sm:flex items-center gap-1.5 px-2.5 py-1.5 rounded-xl text-xs font-medium text-slate-500 hover:text-red-600 hover:bg-red-50 transition-all duration-150 cursor-pointer" do %>
              Sign out
            <% end %>
          </div>
        <% else %>
          <div class="flex items-center gap-2 pl-2 ml-1 border-l border-slate-200">
            <%= link_to "Sign In", new_user_session_path,
                  class: "px-3 py-2 rounded-xl text-sm font-semibold text-slate-600 hover:text-slate-900 hover:bg-slate-100 transition duration-150" %>
            <%= link_to "List Your Store", new_user_registration_path(role: "vendor"),
                  class: "px-4 py-2 bg-green-600 hover:bg-green-700 active:bg-green-800 text-white text-sm font-bold rounded-xl shadow-sm shadow-green-600/25 transition duration-150 whitespace-nowrap" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</nav>
