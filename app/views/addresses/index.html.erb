<% content_for :title, "My Addresses" %>

<div class="max-w-3xl mx-auto px-4 py-10">
  <div class="flex items-center justify-between mb-8">
    <div>
      <h1 class="text-2xl font-bold text-slate-900">My Addresses</h1>
      <p class="text-slate-500 text-sm mt-1">Manage your delivery addresses</p>
    </div>
    <%= link_to new_address_path, class: "flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white font-semibold px-5 py-2.5 rounded-xl transition shadow-sm text-sm" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
      Add Address
    <% end %>
  </div>

  <% if @addresses.any? %>
    <div class="space-y-4">
      <% @addresses.each do |address| %>
        <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-5 flex items-start justify-between gap-4">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 bg-green-50 rounded-xl flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
            </div>
            <div>
              <div class="flex items-center gap-2">
                <p class="font-bold text-slate-900 text-sm"><%= address.city %>, <%= address.province %></p>
                <% if address.is_default? %>
                  <span class="bg-green-100 text-green-700 text-xs font-bold px-2 py-0.5 rounded-full">Default</span>
                <% end %>
              </div>
              <p class="text-slate-500 text-sm mt-0.5"><%= address.line1 %><%= address.line2.present? ? ", #{address.line2}" : "" %></p>
              <% if address.postal_code.present? %>
                <p class="text-slate-400 text-xs mt-0.5">Postal: <%= address.postal_code %></p>
              <% end %>
            </div>
          </div>
          <div class="flex items-center gap-2 flex-shrink-0">
            <%= link_to edit_address_path(address),
                  class: "p-2 text-slate-400 hover:text-slate-700 hover:bg-slate-100 rounded-xl transition" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
            <% end %>
            <%= button_to address_path(address), method: :delete,
                  class: "p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-xl transition",
                  data: { confirm: "Delete this address?" } do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-20 bg-white rounded-2xl border border-slate-200">
      <div class="w-16 h-16 bg-slate-100 rounded-2xl flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-slate-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
      </div>
      <h3 class="text-lg font-semibold text-slate-700 mb-2">No addresses saved</h3>
      <p class="text-slate-400 text-sm mb-5">Add a delivery address to checkout faster</p>
      <%= link_to "Add Your First Address", new_address_path,
            class: "bg-green-600 hover:bg-green-700 text-white font-semibold px-6 py-3 rounded-xl transition" %>
    </div>
  <% end %>
</div>
