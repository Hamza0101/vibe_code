<% content_for :title, "Shop Local, Support Pakistan" %>

<!-- Hero Section -->
<section class="relative bg-gradient-to-br from-green-700 via-green-600 to-emerald-700 text-white overflow-hidden">
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-10 right-10 w-64 h-64 rounded-full bg-white blur-3xl"></div>
    <div class="absolute bottom-10 left-10 w-48 h-48 rounded-full bg-yellow-300 blur-3xl"></div>
  </div>
  <div class="relative max-w-7xl mx-auto px-4 py-20 text-center">
    <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm border border-white/20 px-4 py-1.5 rounded-full text-sm font-medium mb-6">
      <span class="text-yellow-300">🇵🇰</span> Pakistan's #1 Local Business Marketplace
    </div>
    <h1 class="text-4xl md:text-6xl font-bold mb-5 leading-tight tracking-tight">
      Shop Local,<br><span class="text-yellow-300">Support Pakistan</span>
    </h1>
    <p class="text-lg text-green-100 mb-10 max-w-2xl mx-auto">
      Order from your neighborhood grocery stores, pharmacies, and clothing boutiques. Fast delivery, trusted sellers.
    </p>

    <%= form_with url: root_path, method: :get, class: "flex max-w-xl mx-auto shadow-xl rounded-2xl overflow-hidden" do |f| %>
      <div class="relative flex-1">
        <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/>
        </svg>
        <%= f.text_field :q, placeholder: "Search for stores or products...",
              class: "w-full pl-12 pr-4 py-4 text-slate-900 text-base focus:outline-none bg-white",
              value: params[:q] %>
      </div>
      <%= f.submit "Search", class: "bg-amber-500 hover:bg-amber-400 text-white px-6 py-4 font-bold text-base cursor-pointer transition whitespace-nowrap" %>
    <% end %>

    <div class="flex items-center justify-center gap-6 mt-8 text-sm text-green-200">
      <span class="flex items-center gap-1.5"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg> Free delivery on first order</span>
      <span class="flex items-center gap-1.5"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg> Verified local stores</span>
      <span class="flex items-center gap-1.5"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg> Cash on delivery</span>
    </div>
  </div>
</section>

<!-- Categories -->
<section class="max-w-7xl mx-auto px-4 py-14">
  <div class="text-center mb-8">
    <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Shop by Category</h2>
    <p class="text-slate-500 mt-1">Find what you need from local businesses near you</p>
  </div>
  <div class="grid grid-cols-3 gap-4 max-w-lg mx-auto">
    <%= link_to stores_path(category: "grocery"), class: "group bg-white rounded-2xl shadow-sm border border-slate-200 p-8 text-center hover:border-green-400 hover:shadow-md transition-all duration-200" do %>
      <div class="text-5xl mb-3 group-hover:scale-110 transition-transform duration-200">🥦</div>
      <div class="font-semibold text-slate-700 group-hover:text-green-700 text-sm">Grocery</div>
    <% end %>
    <%= link_to stores_path(category: "pharmacy"), class: "group bg-white rounded-2xl shadow-sm border border-slate-200 p-8 text-center hover:border-green-400 hover:shadow-md transition-all duration-200" do %>
      <div class="text-5xl mb-3 group-hover:scale-110 transition-transform duration-200">💊</div>
      <div class="font-semibold text-slate-700 group-hover:text-green-700 text-sm">Pharmacy</div>
    <% end %>
    <%= link_to stores_path(category: "clothing"), class: "group bg-white rounded-2xl shadow-sm border border-slate-200 p-8 text-center hover:border-green-400 hover:shadow-md transition-all duration-200" do %>
      <div class="text-5xl mb-3 group-hover:scale-110 transition-transform duration-200">👗</div>
      <div class="font-semibold text-slate-700 group-hover:text-green-700 text-sm">Clothing</div>
    <% end %>
  </div>
</section>

<!-- Search Results -->
<% if @search_query.present? %>
  <section class="max-w-7xl mx-auto px-4 pb-10">
    <h2 class="text-2xl font-bold mb-6 text-slate-900">
      Results for <span class="text-green-700">"<%= @search_query %>"</span>
    </h2>
    <% if @search_stores.any? %>
      <h3 class="text-base font-semibold mb-4 text-slate-500 uppercase tracking-wide text-xs">Stores</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5 mb-10">
        <%= render partial: "stores/store_card", collection: @search_stores, as: :store %>
      </div>
    <% end %>
    <% if @search_products.any? %>
      <h3 class="text-base font-semibold mb-4 text-slate-500 uppercase tracking-wide text-xs">Products</h3>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-5">
        <%= render partial: "products/product_card", collection: @search_products, as: :product %>
      </div>
    <% end %>
    <% if @search_stores.empty? && @search_products.empty? %>
      <div class="text-center py-16">
        <p class="text-5xl mb-4">🔍</p>
        <p class="text-slate-500 text-lg">No results found for "<%= @search_query %>"</p>
        <p class="text-slate-400 text-sm mt-2">Try searching with different keywords</p>
      </div>
    <% end %>
  </section>
<% end %>

<!-- Featured Stores -->
<% if @featured_stores.any? %>
  <section class="max-w-7xl mx-auto px-4 pb-14">
    <div class="flex items-center justify-between mb-6">
      <div>
        <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Featured Stores</h2>
        <p class="text-slate-500 text-sm mt-0.5">Hand-picked top sellers in your area</p>
      </div>
      <%= link_to "View all stores", stores_path, class: "text-sm font-semibold text-green-700 hover:text-green-800 flex items-center gap-1" do %>
        View all <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
      <% end %>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
      <%= render partial: "stores/store_card", collection: @featured_stores, as: :store %>
    </div>
  </section>
<% end %>

<!-- Recent Stores -->
<section class="max-w-7xl mx-auto px-4 pb-14">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-2xl font-bold text-slate-900 tracking-tight">Recently Added</h2>
      <p class="text-slate-500 text-sm mt-0.5">New businesses joining BazaarPK</p>
    </div>
    <%= link_to stores_path, class: "text-sm font-semibold text-green-700 hover:text-green-800 flex items-center gap-1" do %>
      Browse all <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
    <% end %>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5">
    <%= render partial: "stores/store_card", collection: @recent_stores, as: :store %>
  </div>
</section>

<!-- CTA for Vendors -->
<% unless user_signed_in? %>
  <section class="max-w-7xl mx-auto px-4 pb-16">
    <div class="bg-gradient-to-r from-green-600 to-emerald-700 rounded-3xl p-10 md:p-14 text-center text-white relative overflow-hidden">
      <div class="absolute top-0 right-0 w-64 h-64 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/4"></div>
      <div class="relative">
        <h2 class="text-3xl font-bold mb-3">Own a store? Join BazaarPK today!</h2>
        <p class="text-green-100 text-lg mb-8 max-w-xl mx-auto">Start for free — list up to 20 products, accept orders, and grow your business online.</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <%= link_to "Register Your Store Free", new_user_registration_path(role: "vendor"),
                class: "bg-white text-green-700 hover:bg-green-50 font-bold px-8 py-3.5 rounded-xl text-base transition shadow-md" %>
          <%= link_to "View Pricing", subscriptions_path,
                class: "border border-white/40 text-white hover:bg-white/10 font-semibold px-8 py-3.5 rounded-xl text-base transition" %>
        </div>
      </div>
    </div>
  </section>
<% end %>
