<% content_for :title, "Shop Local, Support Pakistan" %>

<!-- ===================== HERO ===================== -->
<section class="relative overflow-hidden" style="background: linear-gradient(135deg, #0f172a 0%, #052e16 50%, #0f172a 100%);">
  <!-- Background glows -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute -top-32 right-1/4 w-[700px] h-[700px] rounded-full" style="background: radial-gradient(circle, rgba(34,197,94,0.12) 0%, transparent 70%);"></div>
    <div class="absolute bottom-0 -left-20 w-[500px] h-[500px] rounded-full" style="background: radial-gradient(circle, rgba(16,185,129,0.08) 0%, transparent 70%);"></div>
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: url(\"data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='1'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E\");"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-20 pb-16 text-white">

    <!-- Badge -->
    <div class="flex justify-center mb-7">
      <div class="inline-flex items-center gap-2.5 bg-white/8 border border-white/12 rounded-full px-5 py-2">
        <span class="w-1.5 h-1.5 rounded-full bg-green-400 animate-pulse flex-shrink-0"></span>
        <span class="text-green-300 text-xs font-semibold tracking-wide">Pakistan's Local Business Marketplace</span>
      </div>
    </div>

    <!-- Headline -->
    <div class="text-center mb-8">
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold leading-[1.06] tracking-tight">
        Shop Local,<br>
        <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(90deg, #4ade80 0%, #34d399 100%);">Support Pakistan</span>
      </h1>
      <p class="mt-5 text-lg text-slate-400 max-w-xl mx-auto leading-relaxed font-normal">
        Order from your neighborhood grocery stores, pharmacies, and boutiques.
        Fast delivery, cash on delivery.
      </p>
    </div>

    <!-- Search bar -->
    <%= form_with url: root_path, method: :get, class: "max-w-xl mx-auto mb-10" do |f| %>
      <div class="relative flex bg-white/10 backdrop-blur-sm border border-white/15 rounded-2xl overflow-hidden shadow-xl shadow-black/30 focus-within:border-green-500/50 focus-within:bg-white/12 transition-all duration-200">
        <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-slate-400 pointer-events-none flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/>
        </svg>
        <%= f.text_field :q, placeholder: "Search stores and products...",
              class: "flex-1 bg-transparent pl-12 pr-4 py-4 text-white placeholder-slate-400 focus:outline-none text-sm border-0 ring-0",
              value: params[:q], autocomplete: "off" %>
        <%= f.submit "Search",
              class: "bg-green-600 hover:bg-green-500 active:bg-green-700 text-white px-7 py-4 font-semibold text-sm cursor-pointer transition-all duration-150 whitespace-nowrap flex-shrink-0 border-0 my-1 mr-1 rounded-xl" %>
      </div>
    <% end %>

    <!-- Trust badges -->
    <div class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-xs text-slate-500 mb-14">
      <% [
        ["M5 13l4 4L19 7", "Free delivery on 1st order"],
        ["M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z", "Verified local stores"],
        ["M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z", "Cash on delivery"],
        ["M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z", "Real-time tracking"],
      ].each do |icon, text| %>
        <span class="flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 text-green-500 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="<%= icon %>"/></svg>
          <%= text %>
        </span>
      <% end %>
    </div>

    <!-- Stats bar -->
    <div class="max-w-2xl mx-auto">
      <div class="bg-white/5 border border-white/8 rounded-2xl px-6 py-5 grid grid-cols-2 md:grid-cols-4 divide-y md:divide-y-0 md:divide-x divide-white/8">
        <% [["5,000+", "Active Stores"], ["50K+", "Products"], ["200K+", "Customers"], ["10+", "Cities"]].each do |num, label| %>
          <div class="text-center py-2 md:py-0 md:px-4 first:pt-0 last:pb-0 md:first:pt-0 md:last:pb-0">
            <p class="text-xl font-bold text-white"><%= num %></p>
            <p class="text-slate-500 text-xs mt-0.5"><%= label %></p>
          </div>
        <% end %>
      </div>
    </div>

  </div>
</section>

<!-- ===================== CATEGORIES ===================== -->
<section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
  <div class="text-center mb-10">
    <p class="section-eyebrow">Browse by Category</p>
    <h2 class="section-title">Find What You Need</h2>
    <p class="section-sub">From grocery to gadgets — shop from trusted local businesses near you</p>
  </div>

  <div class="grid grid-cols-3 sm:grid-cols-3 lg:grid-cols-6 gap-3 sm:gap-4">
    <% [
      { label: "Grocery",     category: "grocery",     icon_bg: "bg-green-50",  icon_color: "text-green-600",  border: "border-green-200/80 hover:border-green-400",  icon: "M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" },
      { label: "Pharmacy",    category: "pharmacy",    icon_bg: "bg-blue-50",   icon_color: "text-blue-600",   border: "border-blue-200/80 hover:border-blue-400",    icon: "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" },
      { label: "Clothing",    category: "clothing",    icon_bg: "bg-purple-50", icon_color: "text-purple-600", border: "border-purple-200/80 hover:border-purple-400", icon: "M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" },
      { label: "Electronics", category: "electronics", icon_bg: "bg-amber-50",  icon_color: "text-amber-600",  border: "border-amber-200/80 hover:border-amber-400",  icon: "M12 18h.01M8 21h8a2 2 0 002-2v-1a1 1 0 00-1-1H7a1 1 0 00-1 1v1a2 2 0 002 2zM12 2a3 3 0 013 3v1H9V5a3 3 0 013-3z M9 8h6m-5 4h4" },
      { label: "Food",        category: "food",        icon_bg: "bg-red-50",    icon_color: "text-red-600",    border: "border-red-200/80 hover:border-red-400",      icon: "M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" },
      { label: "Home",        category: "home",        icon_bg: "bg-teal-50",   icon_color: "text-teal-600",   border: "border-teal-200/80 hover:border-teal-400",    icon: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" },
    ].each do |cat| %>
      <%= link_to stores_path(category: cat[:category]),
            class: "group bg-white border #{cat[:border]} rounded-2xl p-5 text-center hover:shadow-md hover:-translate-y-1 transition-all duration-200 cursor-pointer" do %>
        <div class="w-11 h-11 <%= cat[:icon_bg] %> rounded-xl flex items-center justify-center mx-auto mb-3 group-hover:scale-110 transition-transform duration-200">
          <svg class="w-5 h-5 <%= cat[:icon_color] %>" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="<%= cat[:icon] %>"/>
          </svg>
        </div>
        <p class="font-semibold text-slate-700 text-xs sm:text-sm group-hover:text-slate-900 transition-colors duration-150"><%= cat[:label] %></p>
      <% end %>
    <% end %>
  </div>
</section>

<!-- ===================== SEARCH RESULTS ===================== -->
<% if @search_query.present? %>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-14">
    <h2 class="text-2xl font-bold mb-2 text-slate-900">
      Results for <span class="text-green-700">"<%= @search_query %>"</span>
    </h2>
    <% if @search_stores.empty? && @search_products.empty? %>
      <div class="text-center py-20 bg-white rounded-2xl border border-slate-200 shadow-sm">
        <svg class="w-12 h-12 text-slate-200 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/></svg>
        <p class="text-slate-700 text-base font-semibold">No results found</p>
        <p class="text-slate-400 text-sm mt-1">Try different keywords or browse by category</p>
      </div>
    <% else %>
      <% if @search_stores.any? %>
        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-4 mt-6">Stores</p>
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5 mb-10">
          <%= render partial: "stores/store_card", collection: @search_stores, as: :store %>
        </div>
      <% end %>
      <% if @search_products.any? %>
        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-4 mt-6">Products</p>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
          <%= render partial: "products/product_card", collection: @search_products, as: :product %>
        </div>
      <% end %>
    <% end %>
  </section>
<% end %>

<!-- ===================== FEATURED STORES ===================== -->
<% if @featured_stores.any? %>
  <section class="bg-white border-y border-slate-100 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-end justify-between mb-8">
        <div>
          <p class="text-xs font-bold text-green-600 uppercase tracking-widest mb-1">Hand-picked</p>
          <h2 class="text-3xl font-black text-slate-900 tracking-tight">Featured Stores</h2>
        </div>
        <%= link_to stores_path, class: "flex items-center gap-1.5 text-sm font-bold text-green-600 hover:text-green-700 transition" do %>
          View all <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
        <% end %>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5">
        <%= render partial: "stores/store_card", collection: @featured_stores, as: :store %>
      </div>
    </div>
  </section>
<% end %>

<!-- ===================== RECENTLY ADDED ===================== -->
<% if @recent_stores.any? %>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="flex items-end justify-between mb-8">
      <div>
        <p class="text-xs font-bold text-slate-500 uppercase tracking-widest mb-1">New on BazaarPK</p>
        <h2 class="text-3xl font-black text-slate-900 tracking-tight">Recently Joined</h2>
      </div>
      <%= link_to stores_path, class: "flex items-center gap-1.5 text-sm font-bold text-green-600 hover:text-green-700 transition" do %>
        Browse all <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
      <% end %>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5">
      <%= render partial: "stores/store_card", collection: @recent_stores, as: :store %>
    </div>
  </section>
<% end %>

<!-- ===================== HOW IT WORKS ===================== -->
<section class="bg-slate-900 text-white py-20">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <p class="text-xs font-bold text-green-400 uppercase tracking-widest mb-2">Simple Process</p>
      <h2 class="text-3xl font-black tracking-tight">How BazaarPK Works</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <% [
        { step: "01", title: "Find a Store", desc: "Browse verified local stores near you — grocery, pharmacy, clothing, and more.", icon: "M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0" },
        { step: "02", title: "Place Your Order", desc: "Add items to your cart and checkout. Cash on delivery — no credit card required.", icon: "M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" },
        { step: "03", title: "Fast Delivery", desc: "The store prepares your order and delivers straight to your doorstep.", icon: "M13 10V3L4 14h7v7l9-11h-7z" },
      ].each do |item| %>
        <div class="text-center">
          <div class="w-14 h-14 bg-green-500/15 border border-green-500/25 rounded-2xl flex items-center justify-center mx-auto mb-4">
            <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="<%= item[:icon] %>"/>
            </svg>
          </div>
          <p class="text-xs font-black text-green-500 tracking-widest mb-2">STEP <%= item[:step] %></p>
          <h3 class="text-lg font-bold text-white mb-2"><%= item[:title] %></h3>
          <p class="text-slate-400 text-sm leading-relaxed"><%= item[:desc] %></p>
        </div>
      <% end %>
    </div>
  </div>
</section>

<!-- ===================== VENDOR CTA ===================== -->
<% unless user_signed_in? %>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="relative bg-gradient-to-br from-green-600 to-emerald-700 rounded-3xl overflow-hidden">
      <div class="absolute inset-0 pointer-events-none overflow-hidden">
        <div class="absolute -top-16 -right-16 w-64 h-64 bg-white/8 rounded-full"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-black/10 rounded-full translate-y-1/2 -translate-x-1/4"></div>
        <div class="absolute inset-0 opacity-5" style="background-image: linear-gradient(rgba(255,255,255,0.15) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.15) 1px, transparent 1px); background-size: 30px 30px;"></div>
      </div>
      <div class="relative grid grid-cols-1 lg:grid-cols-2 gap-10 items-center p-10 md:p-14">
        <div>
          <p class="text-green-200 text-xs font-bold uppercase tracking-widest mb-3">For Business Owners</p>
          <h2 class="text-3xl md:text-4xl font-black text-white leading-tight mb-4">
            Own a store? Start<br>selling online today.
          </h2>
          <p class="text-green-100 text-base leading-relaxed mb-8">
            List up to 20 products for free. Manage orders, track revenue, and even run a POS terminal for walk-in customers — all from one dashboard.
          </p>
          <div class="flex flex-wrap gap-3">
            <%= link_to "Register Your Store Free", new_user_registration_path(role: "vendor"),
                  class: "bg-white text-green-700 hover:bg-green-50 font-bold px-7 py-3.5 rounded-xl text-sm transition shadow-md" %>
            <%= link_to "View Pricing", subscriptions_path,
                  class: "border border-white/40 text-white hover:bg-white/10 font-semibold px-7 py-3.5 rounded-xl text-sm transition" %>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-4 lg:justify-items-end">
          <% [
            ["Free to start", "No credit card needed"],
            ["POS terminal", "For walk-in customers"],
            ["Analytics", "Revenue & order insights"],
            ["JazzCash ready", "Pakistan payments"],
          ].each do |title, sub| %>
            <div class="bg-white/10 border border-white/15 rounded-2xl p-4">
              <p class="font-bold text-white text-sm mb-0.5"><%= title %></p>
              <p class="text-green-200 text-xs"><%= sub %></p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </section>
<% end %>
