<% content_for :title, "Pakistan's Local Business Marketplace" %>

<!-- Hero -->
<section class="bg-gradient-to-r from-green-700 to-green-600 text-white py-16">
  <div class="max-w-7xl mx-auto px-4 text-center">
    <h1 class="text-4xl md:text-5xl font-bold mb-4">Shop Local, Support Pakistan 🇵🇰</h1>
    <p class="text-xl text-green-100 mb-8">Order from your local grocery stores, pharmacies, and clothing shops.</p>

    <%= form_with url: root_path, method: :get, class: "flex max-w-lg mx-auto" do |f| %>
      <%= f.text_field :q, placeholder: "Search for stores or products...",
            class: "flex-1 px-4 py-3 text-gray-800 rounded-l-lg focus:outline-none text-lg",
            value: params[:q] %>
      <%= f.submit "Search", class: "bg-yellow-500 hover:bg-yellow-400 text-white px-6 py-3 rounded-r-lg font-semibold cursor-pointer" %>
    <% end %>
  </div>
</section>

<!-- Categories -->
<section class="max-w-7xl mx-auto px-4 py-10">
  <h2 class="text-2xl font-bold mb-6">Shop by Category</h2>
  <div class="grid grid-cols-3 md:grid-cols-3 gap-4">
    <%= link_to stores_path(category: "grocery"), class: "bg-white rounded-xl shadow p-6 text-center hover:shadow-md transition group" do %>
      <div class="text-5xl mb-3">🥦</div>
      <div class="font-semibold text-gray-700 group-hover:text-green-700">Grocery</div>
    <% end %>
    <%= link_to stores_path(category: "pharmacy"), class: "bg-white rounded-xl shadow p-6 text-center hover:shadow-md transition group" do %>
      <div class="text-5xl mb-3">💊</div>
      <div class="font-semibold text-gray-700 group-hover:text-green-700">Pharmacy</div>
    <% end %>
    <%= link_to stores_path(category: "clothing"), class: "bg-white rounded-xl shadow p-6 text-center hover:shadow-md transition group" do %>
      <div class="text-5xl mb-3">👗</div>
      <div class="font-semibold text-gray-700 group-hover:text-green-700">Clothing</div>
    <% end %>
  </div>
</section>

<!-- Search Results -->
<% if @search_query.present? %>
  <section class="max-w-7xl mx-auto px-4 py-6">
    <h2 class="text-2xl font-bold mb-4">Search results for "<%= @search_query %>"</h2>

    <% if @search_stores.any? %>
      <h3 class="text-lg font-semibold mb-3 text-gray-600">Stores</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-8">
        <%= render partial: "stores/store_card", collection: @search_stores, as: :store %>
      </div>
    <% end %>

    <% if @search_products.any? %>
      <h3 class="text-lg font-semibold mb-3 text-gray-600">Products</h3>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <%= render partial: "products/product_card", collection: @search_products, as: :product %>
      </div>
    <% end %>

    <% if @search_stores.empty? && @search_products.empty? %>
      <p class="text-gray-500 text-center py-8">No results found for "<%= @search_query %>".</p>
    <% end %>
  </section>
<% end %>

<!-- Featured Stores -->
<% if @featured_stores.any? %>
  <section class="max-w-7xl mx-auto px-4 py-10">
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold">⭐ Featured Stores</h2>
      <%= link_to "View all stores →", stores_path, class: "text-green-600 hover:text-green-700 font-medium" %>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
      <%= render partial: "stores/store_card", collection: @featured_stores, as: :store %>
    </div>
  </section>
<% end %>

<!-- Recent Stores -->
<section class="max-w-7xl mx-auto px-4 py-10 bg-white rounded-xl shadow-sm">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-2xl font-bold">🆕 Recently Added Stores</h2>
    <%= link_to "Browse all →", stores_path, class: "text-green-600 hover:text-green-700 font-medium" %>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <%= render partial: "stores/store_card", collection: @recent_stores, as: :store %>
  </div>
</section>

<!-- CTA for Vendors -->
<% unless user_signed_in? %>
  <section class="bg-yellow-50 border border-yellow-200 rounded-xl mx-4 my-10 p-8 text-center max-w-4xl mx-auto">
    <h2 class="text-2xl font-bold text-gray-800 mb-3">Own a store? Join BazaarPK today!</h2>
    <p class="text-gray-600 mb-6">Start for free. List up to 20 products. Upgrade when you're ready to grow.</p>
    <%= link_to "Register Your Store — It's Free", new_user_registration_path(role: "vendor"),
          class: "bg-green-600 hover:bg-green-700 text-white font-bold px-8 py-3 rounded-lg text-lg" %>
  </section>
<% end %>
