<% content_for :page_title, @user.name || @user.email %>

<div class="max-w-2xl">
  <%= link_to admin_users_path, class: "inline-flex items-center gap-1 text-sm text-slate-500 hover:text-slate-700 font-medium mb-6" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back to Users
  <% end %>

  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6 mb-5">
    <div class="flex items-start justify-between gap-4 mb-6">
      <div class="flex items-center gap-4">
        <div class="w-14 h-14 rounded-2xl bg-slate-200 flex items-center justify-center text-xl font-black text-slate-600">
          <%= @user.name&.first&.upcase || @user.email.first.upcase %>
        </div>
        <div>
          <h2 class="text-xl font-bold text-slate-900"><%= @user.name || "No name" %></h2>
          <p class="text-slate-500 text-sm"><%= @user.email %></p>
          <span class="inline-flex mt-1 px-2.5 py-0.5 rounded-full text-xs font-semibold
            <%= @user.admin? ? 'bg-red-100 text-red-700' : @user.vendor? ? 'bg-blue-100 text-blue-700' : 'bg-slate-100 text-slate-600' %>">
            <%= @user.role.humanize %>
          </span>
        </div>
      </div>
      <%= link_to edit_admin_user_path(@user), class: "bg-slate-800 hover:bg-slate-900 text-white text-xs font-semibold px-4 py-2.5 rounded-xl transition" do %>
        Edit User
      <% end %>
    </div>

    <dl class="grid grid-cols-2 gap-4 text-sm">
      <div class="bg-slate-50 rounded-xl p-4">
        <dt class="text-xs font-bold text-slate-500 uppercase tracking-wide mb-1">Phone</dt>
        <dd class="font-semibold text-slate-900"><%= @user.phone || "Not provided" %></dd>
      </div>
      <div class="bg-slate-50 rounded-xl p-4">
        <dt class="text-xs font-bold text-slate-500 uppercase tracking-wide mb-1">Joined</dt>
        <dd class="font-semibold text-slate-900"><%= @user.created_at.strftime("%B %d, %Y") %></dd>
      </div>
      <div class="bg-slate-50 rounded-xl p-4">
        <dt class="text-xs font-bold text-slate-500 uppercase tracking-wide mb-1">Orders</dt>
        <dd class="font-semibold text-slate-900"><%= @user.orders.count %></dd>
      </div>
      <% if @user.vendor? && @user.store %>
        <div class="bg-slate-50 rounded-xl p-4">
          <dt class="text-xs font-bold text-slate-500 uppercase tracking-wide mb-1">Store</dt>
          <dd class="font-semibold text-slate-900">
            <%= link_to @user.store.name, admin_store_path(@user.store), class: "text-green-700 hover:text-green-800" %>
          </dd>
        </div>
      <% end %>
    </dl>
  </div>

  <!-- Danger zone -->
  <% unless @user == current_user %>
    <div class="bg-white rounded-2xl border border-red-200 shadow-sm p-5">
      <h3 class="text-xs font-bold text-red-500 uppercase tracking-wide mb-3">Danger Zone</h3>
      <%= button_to admin_user_path(@user), method: :delete,
            class: "bg-red-50 hover:bg-red-100 text-red-600 font-semibold text-sm px-5 py-2.5 rounded-xl border border-red-200 transition",
            data: { confirm: "Delete #{@user.email}? This cannot be undone." } do %>
        Delete This User
      <% end %>
    </div>
  <% end %>
</div>
