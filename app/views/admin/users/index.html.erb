<% content_for :page_title, "Users" %>

<div class="flex items-center justify-between mb-6">
  <%= form_with url: admin_users_path, method: :get, class: "flex gap-2" do |f| %>
    <div class="relative">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/></svg>
      <%= f.text_field :q, placeholder: "Search users...", value: params[:q],
            class: "pl-9 pr-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-green-500 w-64" %>
    </div>
    <%= f.submit "Search", class: "bg-slate-800 hover:bg-slate-900 text-white px-4 py-2.5 rounded-xl text-sm cursor-pointer font-semibold transition" %>
    <% if params[:q].present? %>
      <%= link_to "Clear", admin_users_path, class: "px-4 py-2.5 border border-slate-200 rounded-xl text-sm text-slate-500 hover:text-slate-700 transition" %>
    <% end %>
  <% end %>
</div>

<div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 border-b border-slate-200">
      <tr>
        <th class="px-5 py-3.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">User</th>
        <th class="px-5 py-3.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Role</th>
        <th class="px-5 py-3.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Phone</th>
        <th class="px-5 py-3.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Joined</th>
        <th class="px-5 py-3.5"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @users.each do |user| %>
        <tr class="hover:bg-slate-50/50 transition">
          <td class="px-5 py-4">
            <div class="flex items-center gap-3">
              <div class="w-8 h-8 rounded-xl bg-slate-200 flex items-center justify-center text-xs font-bold text-slate-600">
                <%= user.name&.first&.upcase || user.email.first.upcase %>
              </div>
              <div>
                <p class="font-semibold text-slate-900"><%= user.name || "—" %></p>
                <p class="text-xs text-slate-400"><%= user.email %></p>
              </div>
            </div>
          </td>
          <td class="px-5 py-4">
            <span class="inline-flex px-2.5 py-0.5 rounded-full text-xs font-semibold
              <%= user.admin? ? 'bg-red-100 text-red-700' : user.vendor? ? 'bg-blue-100 text-blue-700' : 'bg-slate-100 text-slate-600' %>">
              <%= user.role.humanize %>
            </span>
          </td>
          <td class="px-5 py-4 text-slate-600 text-sm"><%= user.phone || "—" %></td>
          <td class="px-5 py-4 text-slate-500 text-xs"><%= user.created_at.strftime("%b %d, %Y") %></td>
          <td class="px-5 py-4 text-right">
            <div class="flex items-center justify-end gap-1.5">
              <%= link_to admin_user_path(user), class: "p-2 text-slate-400 hover:text-slate-700 hover:bg-slate-100 rounded-xl transition" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/></svg>
              <% end %>
              <%= link_to edit_admin_user_path(user), class: "p-2 text-slate-400 hover:text-slate-700 hover:bg-slate-100 rounded-xl transition" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
              <% end %>
              <% unless user == current_user %>
                <%= button_to admin_user_path(user), method: :delete,
                      class: "p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-xl transition",
                      data: { confirm: "Delete #{user.email}?" } do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                <% end %>
              <% end %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <div class="px-5 py-4 border-t border-slate-100"><%== pagy_nav(@pagy) %></div>
</div>
