<% content_for :page_title, "Edit User" %>

<div class="max-w-xl">
  <%= link_to admin_user_path(@user), class: "inline-flex items-center gap-1 text-sm text-slate-500 hover:text-slate-700 font-medium mb-6" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
    Back to User
  <% end %>

  <div class="bg-white rounded-2xl border border-slate-200 shadow-sm p-6">
    <h2 class="font-bold text-slate-900 mb-5">Edit: <%= @user.email %></h2>

    <%= form_with model: [:admin, @user], class: "space-y-5" do |f| %>
      <% if @user.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-xl p-4 text-sm text-red-700">
          <% @user.errors.full_messages.each do |msg| %>
            <p>• <%= msg %></p>
          <% end %>
        </div>
      <% end %>

      <div>
        <%= f.label :name, "Full Name", class: "block text-xs font-bold text-slate-500 uppercase tracking-wide mb-1.5" %>
        <%= f.text_field :name, class: "w-full border border-slate-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" %>
      </div>

      <div>
        <%= f.label :email, "Email Address", class: "block text-xs font-bold text-slate-500 uppercase tracking-wide mb-1.5" %>
        <%= f.email_field :email, class: "w-full border border-slate-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" %>
      </div>

      <div>
        <%= f.label :phone, "Phone Number", class: "block text-xs font-bold text-slate-500 uppercase tracking-wide mb-1.5" %>
        <%= f.text_field :phone, class: "w-full border border-slate-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" %>
      </div>

      <div>
        <%= f.label :role, "Role", class: "block text-xs font-bold text-slate-500 uppercase tracking-wide mb-1.5" %>
        <%= f.select :role, [["Customer", "customer"], ["Vendor", "vendor"], ["Admin", "admin"]],
              {}, class: "w-full border border-slate-200 rounded-xl px-4 py-3 text-sm focus:outline-none focus:ring-2 focus:ring-green-500" %>
        <p class="text-xs text-amber-600 mt-1 font-medium">⚠ Changing role affects access permissions</p>
      </div>

      <div class="flex items-center gap-3 pt-2">
        <%= f.submit "Save Changes", class: "bg-green-600 hover:bg-green-700 text-white font-bold px-8 py-3 rounded-xl cursor-pointer transition shadow-sm" %>
        <%= link_to "Cancel", admin_user_path(@user), class: "text-slate-500 hover:text-slate-700 font-medium text-sm px-4 py-3" %>
      </div>
    <% end %>
  </div>
</div>
