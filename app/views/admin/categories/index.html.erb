<% content_for :page_title, "Categories" %>

<div class="flex items-center justify-between mb-6">
  <%= link_to new_admin_category_path, class: "flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white font-semibold px-4 py-2.5 rounded-xl transition shadow-sm text-sm" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    New Category
  <% end %>
</div>

<div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
  <% if @categories.any? %>
    <table class="w-full text-sm">
      <thead class="bg-slate-50 border-b border-slate-200">
        <tr>
          <th class="px-5 py-3.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Name</th>
          <th class="px-5 py-3.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Type</th>
          <th class="px-5 py-3.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Subcategories</th>
          <th class="px-5 py-3.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Position</th>
          <th class="px-5 py-3.5"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @categories.each do |category| %>
          <tr class="hover:bg-slate-50/50 transition">
            <td class="px-5 py-4 font-semibold text-slate-900"><%= category.name %></td>
            <td class="px-5 py-4">
              <span class="text-xs px-2.5 py-0.5 rounded-full font-medium
                <%= category.store_type == 'grocery' ? 'bg-green-100 text-green-700' : category.store_type == 'pharmacy' ? 'bg-blue-100 text-blue-700' : 'bg-purple-100 text-purple-700' %>">
                <%= category.store_type&.humanize || "All" %>
              </span>
            </td>
            <td class="px-5 py-4 text-slate-600"><%= category.subcategories.count %></td>
            <td class="px-5 py-4 text-slate-600"><%= category.position %></td>
            <td class="px-5 py-4 text-right">
              <div class="flex items-center justify-end gap-1.5">
                <%= link_to edit_admin_category_path(category), class: "p-2 text-slate-400 hover:text-slate-700 hover:bg-slate-100 rounded-xl transition" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                <% end %>
                <%= button_to admin_category_path(category), method: :delete,
                      class: "p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-xl transition",
                      data: { confirm: "Delete #{category.name}?" } do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                <% end %>
              </div>
            </td>
          </tr>
          <% category.subcategories.each do |sub| %>
            <tr class="hover:bg-slate-50/50 transition bg-slate-50/30">
              <td class="px-5 py-3 pl-10 text-slate-600">
                <span class="text-slate-300 mr-2">└</span><%= sub.name %>
              </td>
              <td class="px-5 py-3">
                <span class="text-xs px-2 py-0.5 rounded-full bg-slate-100 text-slate-500 font-medium">Subcategory</span>
              </td>
              <td class="px-5 py-3 text-slate-400">—</td>
              <td class="px-5 py-3 text-slate-500"><%= sub.position %></td>
              <td class="px-5 py-3 text-right">
                <div class="flex items-center justify-end gap-1.5">
                  <%= link_to edit_admin_category_path(sub), class: "p-2 text-slate-400 hover:text-slate-700 hover:bg-slate-100 rounded-xl transition" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                  <% end %>
                  <%= button_to admin_category_path(sub), method: :delete,
                        class: "p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-xl transition",
                        data: { confirm: "Delete #{sub.name}?" } do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="text-center py-20">
      <p class="text-4xl mb-3">🏷️</p>
      <h3 class="text-lg font-semibold text-slate-700 mb-2">No categories yet</h3>
      <p class="text-slate-400 text-sm mb-5">Add categories to organize products</p>
      <%= link_to "Create First Category", new_admin_category_path,
            class: "bg-green-600 hover:bg-green-700 text-white font-semibold px-6 py-3 rounded-xl text-sm transition" %>
    </div>
  <% end %>
</div>
