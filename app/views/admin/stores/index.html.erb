<% content_for :page_title, "Stores" %>

<div class="flex items-center justify-between mb-6">
  <%= form_with url: admin_stores_path, method: :get, class: "flex gap-2" do |f| %>
    <div class="relative">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0"/></svg>
      <%= f.text_field :q, placeholder: "Search stores...", value: params[:q],
            class: "pl-9 pr-4 py-2.5 border border-slate-200 rounded-xl text-sm focus:outline-none focus:ring-2 focus:ring-green-500 w-64" %>
    </div>
    <%= f.submit "Search", class: "bg-slate-800 hover:bg-slate-900 text-white px-4 py-2.5 rounded-xl text-sm cursor-pointer font-semibold transition" %>
    <% if params[:q].present? %>
      <%= link_to "Clear", admin_stores_path, class: "px-4 py-2.5 border border-slate-200 rounded-xl text-sm text-slate-500 hover:text-slate-700 hover:bg-slate-50 transition font-medium" %>
    <% end %>
  <% end %>
</div>

<div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
  <table class="w-full text-sm">
    <thead class="bg-slate-50 border-b border-slate-200">
      <tr>
        <th class="px-5 py-3.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Store</th>
        <th class="px-5 py-3.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Owner</th>
        <th class="px-5 py-3.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Category</th>
        <th class="px-5 py-3.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Plan</th>
        <th class="px-5 py-3.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Status</th>
        <th class="px-5 py-3.5"></th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @stores.each do |store| %>
        <tr class="hover:bg-slate-50/50 transition">
          <td class="px-5 py-4">
            <p class="font-semibold text-slate-900"><%= store.name %></p>
            <p class="text-xs text-slate-400 mt-0.5"><%= store.city %></p>
          </td>
          <td class="px-5 py-4 text-xs text-slate-500 max-w-[140px] truncate"><%= store.user.email %></td>
          <td class="px-5 py-4">
            <span class="text-xs px-2 py-0.5 rounded-full font-medium
              <%= store.grocery? ? 'bg-green-100 text-green-700' : store.pharmacy? ? 'bg-blue-100 text-blue-700' : 'bg-purple-100 text-purple-700' %>">
              <%= store.category.humanize %>
            </span>
          </td>
          <td class="px-5 py-4 text-xs text-slate-600 font-medium"><%= store.subscription_plan&.name || "Free" %></td>
          <td class="px-5 py-4">
            <div class="flex items-center gap-1.5 flex-wrap">
              <span class="inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-semibold
                <%= store.verified? ? 'bg-green-100 text-green-700' : 'bg-amber-100 text-amber-700' %>">
                <span class="w-1.5 h-1.5 rounded-full <%= store.verified? ? 'bg-green-500' : 'bg-amber-500' %>"></span>
                <%= store.verified? ? "Verified" : "Pending" %>
              </span>
              <% if store.featured? %>
                <span class="text-xs px-2 py-0.5 rounded-full bg-yellow-100 text-yellow-700 font-semibold">Featured</span>
              <% end %>
            </div>
          </td>
          <td class="px-5 py-4">
            <div class="flex items-center justify-end gap-1.5">
              <%= button_to verify_admin_store_path(store), method: :patch,
                    class: "px-3 py-1.5 rounded-lg text-xs font-semibold transition cursor-pointer #{ store.verified? ? 'bg-red-50 text-red-600 hover:bg-red-100' : 'bg-green-50 text-green-700 hover:bg-green-100' }" do %>
                <%= store.verified? ? "Unverify" : "Verify" %>
              <% end %>
              <%= button_to toggle_featured_admin_store_path(store), method: :patch,
                    class: "px-3 py-1.5 rounded-lg text-xs font-semibold bg-slate-100 text-slate-600 hover:bg-slate-200 transition cursor-pointer" do %>
                <%= store.featured? ? "Unfeature" : "Feature" %>
              <% end %>
              <%= link_to "Edit", edit_admin_store_path(store),
                    class: "p-2 text-slate-400 hover:text-slate-700 hover:bg-slate-100 rounded-lg transition" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  <div class="px-5 py-4 border-t border-slate-100"><%== pagy_nav(@pagy) %></div>
</div>
