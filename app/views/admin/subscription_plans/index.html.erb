<% content_for :page_title, "Subscription Plans" %>

<div class="flex items-center justify-between mb-6">
  <%= link_to new_admin_subscription_plan_path, class: "flex items-center gap-2 bg-green-600 hover:bg-green-700 text-white font-semibold px-4 py-2.5 rounded-xl transition shadow-sm text-sm" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    New Plan
  <% end %>
</div>

<div class="bg-white rounded-2xl border border-slate-200 shadow-sm overflow-hidden">
  <% if @plans.any? %>
    <table class="w-full text-sm">
      <thead class="bg-slate-50 border-b border-slate-200">
        <tr>
          <th class="px-5 py-3.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Plan</th>
          <th class="px-5 py-3.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Price</th>
          <th class="px-5 py-3.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Products</th>
          <th class="px-5 py-3.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Features</th>
          <th class="px-5 py-3.5 text-left text-xs font-bold text-slate-500 uppercase tracking-wide">Subscribers</th>
          <th class="px-5 py-3.5"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @plans.each do |plan| %>
          <tr class="hover:bg-slate-50/50 transition">
            <td class="px-5 py-4">
              <p class="font-bold text-slate-900"><%= plan.name %></p>
              <p class="text-xs text-slate-400 mt-0.5"><%= plan.slug %></p>
            </td>
            <td class="px-5 py-4 font-semibold text-slate-800">
              <% if plan.free? %>
                <span class="text-green-700">Free</span>
              <% else %>
                Rs. <%= number_with_delimiter(plan.price_pkr) %>/mo
              <% end %>
            </td>
            <td class="px-5 py-4 text-slate-700">
              <%= plan.product_limit.nil? ? "Unlimited" : plan.product_limit %>
            </td>
            <td class="px-5 py-4">
              <div class="flex flex-wrap gap-1">
                <% %w[analytics featured sms bulk_import].each do |feat| %>
                  <% if plan.feature?(feat) %>
                    <span class="text-xs px-2 py-0.5 rounded bg-green-100 text-green-700 font-medium"><%= feat.humanize %></span>
                  <% end %>
                <% end %>
              </div>
            </td>
            <td class="px-5 py-4">
              <span class="font-bold text-slate-900"><%= plan.store_subscriptions.active.count rescue 0 %></span>
              <span class="text-slate-400 text-xs"> stores</span>
            </td>
            <td class="px-5 py-4 text-right">
              <div class="flex items-center justify-end gap-1.5">
                <%= link_to edit_admin_subscription_plan_path(plan), class: "p-2 text-slate-400 hover:text-slate-700 hover:bg-slate-100 rounded-xl transition" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/></svg>
                <% end %>
                <%= button_to admin_subscription_plan_path(plan), method: :delete,
                      class: "p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-xl transition",
                      data: { confirm: "Delete #{plan.name}?" } do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <div class="text-center py-20">
      <p class="text-4xl mb-3">💳</p>
      <h3 class="text-lg font-semibold text-slate-700 mb-2">No plans yet</h3>
      <p class="text-slate-400 text-sm mb-5">Create subscription plans for vendors</p>
      <%= link_to "Create First Plan", new_admin_subscription_plan_path,
            class: "bg-green-600 hover:bg-green-700 text-white font-semibold px-6 py-3 rounded-xl text-sm transition" %>
    </div>
  <% end %>
</div>
